local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Plr = Players.LocalPlayer

--========================================================================
-- 0. ĐỌC CẤU HÌNH TỪ GETGENV() VÀ TỰ ĐỘNG CHỌN PHE
--========================================================================
local selectedTeam = "Marines" -- Mặc định nếu người dùng không nhập gì
if getgenv().Config and getgenv().Config.Team then
    if getgenv().Config.Team == "Pirates" or getgenv().Config.Team == "Marines" then
        selectedTeam = getgenv().Config.Team
    end
end

local function AutoJoinTeam()
    if not Plr.Team or (Plr.Team.Name ~= "Marines" and Plr.Team.Name ~= "Pirates") then
        pcall(function() 
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_"):InvokeServer("SetTeam", selectedTeam) 
        end)
    end
end

-- Chạy ngay lập tức khi load script để vượt màn hình chọn phe
AutoJoinTeam()

