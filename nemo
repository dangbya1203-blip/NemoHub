-- SECTION 16: AUTO FARM STATE MACHINE
--==============================================================================
local AutoFarm = { state="IDLE", data=nil, cooldown=0 }

local function farmTick()
    if AutoFarm.state == "IDLE" then return end
    local now = tick()
    if now < AutoFarm.cooldown then return end
    local hrp = getHRP()
    if not hrp then return end

    if AutoFarm.state == "GET_QUEST" then
        AutoFarm.data = QuestModule.GetData()
        if not AutoFarm.data then return end
        if QuestModule.HasActive() then
            if not string.find(QuestModule.GetTitle(), AutoFarm.data.MobName, 1, true) then
                QuestModule.Abandon()
                AutoFarm.cooldown = now + 0.7
            else
                AutoFarm.state = "FIND_MOB"
            end
        else
            AutoFarm.state = "TRAVEL_NPC"
        end

    elseif AutoFarm.state == "TRAVEL_NPC" then
        TpModule.Go(AutoFarm.data.NPCPos)
        if (hrp.Position - AutoFarm.data.NPCPos.Position).Magnitude < 10 then
            AutoFarm.state = "ACCEPT"
        end

    elseif AutoFarm.state == "ACCEPT" then
        QuestModule.Accept(AutoFarm.data)
        AutoFarm.cooldown = now + 0.7
        AutoFarm.state    = "FIND_MOB"

    elseif AutoFarm.state == "FIND_MOB" then
        if not QuestModule.HasActive() then
            AutoFarm.state = "GET_QUEST" return
        end
        local mobs = MobModule.GetAlive(AutoFarm.data.MobName)
        if #mobs == 0 then return end
        local tHRP = mobs[1]:FindFirstChild("HumanoidRootPart")
        if not tHRP then return end
        TpModule.Go(tHRP.CFrame + AutoFarm.data.FlyOffset or CFG.FlyOffset)
        MobModule.BringAll(AutoFarm.data.MobName)
    end
end

function AutoFarm.Start()
    local hrp = getHRP()
    if hrp and _anchor then _anchor.CFrame = hrp.CFrame end
    TpModule.SetActive(true)
    AutoFarm.state = "GET_QUEST"
end

function AutoFarm.Stop()
    AutoFarm.state = "IDLE"
    TpModule.SetActive(false)
    pcall(function() if TpModule._tween then TpModule._tween:Cancel() end end)
end

