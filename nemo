--========================================================================
-- 2. FAST ATTACK MODULE
--========================================================================
local FastAttackModule = {}
FastAttackModule.Rate = 0.05 

-- (Lưu ý: Net thực tế của BF cần dùng getupvalue, đây là bản giả lập chống lỗi)
local Net = {
    ["RE/RegisterAttack"] = ReplicatedStorage:FindFirstChild("RegisterAttack") or { FireServer = function() end },
    ["RE/RegisterHit"] = ReplicatedStorage:FindFirstChild("RegisterHit") or { FireServer = function() end }
}

function FastAttackModule.GetAllTargets(character)
    local targets = {}
    local enemies = workspace:FindFirstChild("Enemies")
    if enemies then
        for _, enemy in pairs(enemies:GetChildren()) do
            local humanoid = enemy:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                table.insert(targets, enemy)
            end
        end
    end
    return targets
end

function FastAttackModule.GetTargetParts(targets)
    local targetParts = {}
    for _, target in pairs(targets) do
        local head = target:FindFirstChild("Head")
        if head then
            table.insert(targetParts, {target, head})
        end
    end
    return targetParts
end

function FastAttackModule.ExecuteFastAttack()
    local character = Plr.Character
    if not character then return end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    local targets = FastAttackModule.GetAllTargets(character)
    if #targets < 1 then return end
    
    local targetParts = FastAttackModule.GetTargetParts(targets)
    if #targetParts < 1 then return end
    
    local attackRemote = Net["RE/RegisterAttack"]
    local hitRemote = Net["RE/RegisterHit"]
    
    if attackRemote and hitRemote then
        pcall(function()
            attackRemote:FireServer(FastAttackModule.Rate)
            local targetHead = targetParts[1][2]
            hitRemote:FireServer(targetHead, targetParts)
        end)
    end
end

