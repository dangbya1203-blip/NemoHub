-- Random delay giữa min-max để hành vi không đều đặn như bot
local function hrand(mn, mx)
    return mn + math.random() * (mx - mn)
end
-- hrand: dùng trong jitterCF, anti-AFK, fast attack, chest fire, v.v.

-- Jitter CFrame: dịch ngẫu nhiên trong bán kính r studs trên mặt phẳng ngang
local function jitterCF(cf, r)
    r = r or TP_JITTER
    local angle = math.random() * math.pi * 2
    local dist  = math.random() * r
    return cf * CFrame.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
end

