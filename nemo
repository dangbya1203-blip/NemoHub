local function GetQuestData()
    local level = Plr.Data.Level.Value
    if level >= 1 and level <= 14 then
        return { NPCName = "Bandit Quest Giver", QuestName = "BanditQuest1", QuestNum = 1, MobName = "Bandit", NPCPos = CFrame.new(1059.37, 15.44, 1550.42) }
    elseif level >= 15 and level <= 29 then
        if level <= 19 then
            return { NPCName = "Adventurer", QuestName = "JungleQuest", QuestNum = 1, MobName = "Monkey", NPCPos = CFrame.new(-1594, 36.8, 153.3) }
        else
            return { NPCName = "Adventurer", QuestName = "JungleQuest", QuestNum = 2, MobName = "Gorilla", NPCPos = CFrame.new(-1594, 36.8, 153.3) }
        end
    elseif level >= 30 and level <= 59 then
        if level <= 39 then
            return { NPCName = "Pirate", QuestName = "BuggyQuest1", QuestNum = 1, MobName = "Pirate", NPCPos = CFrame.new(-1141, 4.7, 3827) }
        else
            return { NPCName = "Pirate", QuestName = "BuggyQuest1", QuestNum = 2, MobName = "Brute", NPCPos = CFrame.new(-1141, 4.7, 3827) }
        end
    end
    return nil -- Bổ sung thêm level ở đây sau
end

local function HasQuest()
    local playerGui = Plr:FindFirstChild("PlayerGui")
    if playerGui and playerGui:FindFirstChild("Main") and playerGui.Main:FindFirstChild("Quest") then
        return playerGui.Main.Quest.Visible
    end
    return false
end

--========================================================================
-- 3. TÍNH NĂNG GOM QUÁI & DI CHUYỂN (BRING MOBS / TWEEN)
--========================================================================
local function TweenObject(Object, Pos, Speed)
    Speed = Speed or 300
    if not Object or not Pos then return end
    local Distance = (Pos.Position - Object.Position).Magnitude
    local info = TweenInfo.new(Distance / Speed, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(Object, info, {CFrame = Pos})
    tween:Play()
end

local function GetMobPosition(EnemiesName)
    local pos = Vector3.zero
    local count = 0
    for _, v in pairs(Workspace.Enemies:GetChildren()) do
        if v.Name == EnemiesName and v:FindFirstChild("HumanoidRootPart") then
            pos += v.HumanoidRootPart.Position
            count += 1
        end
    end
    if count == 0 then return nil end
    return pos / count
end

local function ExecuteBringMobs(TargetMobName)
    local enemies = Workspace.Enemies:GetChildren()
    if #enemies == 0 then return end

    local mobPos = GetMobPosition(TargetMobName)
    if not mobPos then return end

    for _, v in pairs(Workspace.Enemies:GetChildren()) do
        if v.Name == TargetMobName and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            local hrp = v.HumanoidRootPart
            local humanoid = v.Humanoid
            
            if humanoid.Health > 0 and Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart") then
                if (hrp.Position - Plr.Character.HumanoidRootPart.Position).Magnitude <= 350 then
                    local TargetCFrame = CFrame.new(mobPos.X, mobPos.Y, mobPos.Z)
                    local Distance = (hrp.Position - TargetCFrame.Position).Magnitude

                    if Distance > 3 and Distance <= 280 then
                        TweenObject(hrp, TargetCFrame, 300)
                        hrp.CanCollide = false
                        humanoid.WalkSpeed = 0
                        humanoid.JumpPower = 0
                        pcall(function()
                            sethiddenproperty(Plr, "SimulationRadius", math.huge)
                        end)
                    end
                end
            end
        end
    end
end

--========================================================================
-- 4. FAST ATTACK MODULE
--========================================================================
local FastAttackModule = {}
FastAttackModule.Rate = 0.05 
local Net = {
    ["RE/RegisterAttack"] = ReplicatedStorage:FindFirstChild("RegisterAttack") or { FireServer = function() end },
    ["RE/RegisterHit"] = ReplicatedStorage:FindFirstChild("RegisterHit") or { FireServer = function() end }
}

function FastAttackModule.GetAllTargets(character)
    local targets = {}
    local enemies = Workspace:FindFirstChild("Enemies")
    if enemies then
        for _, enemy in pairs(enemies:GetChildren()) do
            local humanoid = enemy:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                table.insert(targets, enemy)
            end
        end
    end
    return targets
end

function FastAttackModule.GetTargetParts(targets)
    local targetParts = {}
    for _, target in pairs(targets) do
        local head = target:FindFirstChild("Head")
        if head then table.insert(targetParts, {target, head}) end
    end
    return targetParts
end

function FastAttackModule.ExecuteFastAttack()
    local character = Plr.Character
    if not character then return end
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    local targets = FastAttackModule.GetAllTargets(character)
    if #targets < 1 then return end
    
    local targetParts = FastAttackModule.GetTargetParts(targets)
    if #targetParts < 1 then return end
    
    local attackRemote = Net["RE/RegisterAttack"]
    local hitRemote = Net["RE/RegisterHit"]
    
    if attackRemote and hitRemote then
        pcall(function()
            attackRemote:FireServer(FastAttackModule.Rate)
            local targetHead = targetParts[1][2]
            hitRemote:FireServer(targetHead, targetParts)
        end)
    end
end

