-- Dodge offsets để nhảy cóc quanh boss
local lastDodge   = 0
local dodgeIndex  = 1
local dodgeOffsets = {
    CFrame.new(0,  30,  25),
    CFrame.new(25, 30,  0),
    CFrame.new(-25,30,  0),
    CFrame.new(0,  30, -25),
