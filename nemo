    local function findNearestGate(targetCF)
        local targetPos  = targetCF.Position
        local playerPos  = Player.Character and Player.Character.HumanoidRootPart
                           and Player.Character.HumanoidRootPart.Position
        if not playerPos then return nil end
        local bestGate, bestDist = nil, math.huge
        for _, gate in ipairs(GATES) do
            local d = (gate - targetPos).Magnitude
            if d < bestDist then bestDist = d; bestGate = gate end
        end
        if bestGate and bestDist < (targetPos - playerPos).Magnitude then
            return bestGate
        end
        return nil
    end

    local function TravelTo(cf)
        pcall(function()
            local char = Player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not hrp or not cf then return end
            local gate = findNearestGate(cf)
            if gate and CommF then
                task.spawn(function()
                    pcall(function()
                        CommF:InvokeServer("requestEntrance", gate)
                        hrp.CFrame = hrp.CFrame + Vector3.new(0, 50, 0)
                    end)
                end)
                task.wait(0.5)
            end
            local dist = (hrp.Position - cf.Position).Magnitude
            if dist < 5 then return end
            -- PartTele pattern: tween a Part and sync HRP to it so physics doesn't override
            local partTele = Instance.new("Part")
            partTele.Name         = "TravelPartTele"
            partTele.Size         = Vector3.new(4, 1, 4)
            partTele.Anchored     = true
            partTele.CanCollide   = false
            partTele.Transparency = 1
            partTele.CFrame       = hrp.CFrame
            partTele.Parent       = char
            partTele:GetPropertyChangedSignal("CFrame"):Connect(function()
                task.wait()
                local c2 = Player.Character
                local h2 = c2 and c2:FindFirstChild("HumanoidRootPart")
                if h2 and partTele.Parent then h2.CFrame = partTele.CFrame end
            end)
            local TweenSpeed2 = 300
            local info = TweenInfo.new(dist / TweenSpeed2, Enum.EasingStyle.Linear)
            local tw = TweenService:Create(partTele, info, {CFrame = cf})
            tw:Play()
            tw.Completed:Connect(function()
                if partTele and partTele.Parent then partTele:Destroy() end
            end)
        end)
    end

