-- Bay lên đầu boss + để Fast Attack core tự đánh
local function PositionOnBoss(boss)
    local root = boss:FindFirstChild("HumanoidRootPart")
    local hum  = boss:FindFirstChild("Humanoid")
    if not root or not hum or hum.Health <= 0 then return end
    local char = LocalPlayer.Character
    if not char then return end
    local plrRoot = char:FindFirstChild("HumanoidRootPart")
    if not plrRoot then return end
    if RandomCFrame then
        -- Humanize: dodge timing không cố định 0.5s
        if tick() - lastDodge >= hrand(0.4, 0.7) then
            dodgeIndex = dodgeIndex % #dodgeOffsets + 1
            lastDodge = tick()
        end
        local targetPos = (root.CFrame * dodgeOffsets[dodgeIndex]).Position
        -- Thêm jitter nhỏ vào vị trí đứng để không đứng y hệt mỗi lần
        local jx = (math.random() - 0.5) * 3
        local jz = (math.random() - 0.5) * 3
        plrRoot.CFrame = CFrame.new(targetPos + Vector3.new(jx, 0, jz), root.Position)
    else
        local targetPos = (root.CFrame * CFrame.new(0, 15, 0)).Position
        plrRoot.CFrame = CFrame.new(targetPos, root.Position)
    end
end

