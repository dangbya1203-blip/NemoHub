-- ==========================================
--[[
  Flow:
  1. Chưa có God's Chalice / Sweet Chalice → skip, về farm Chest chờ nhặt từ rương
  2. Thiếu Conjured Cocoa (<10) → farm Cocoa Warrior / Chocolate Bar Battler
  3. Có God's Chalice + ≥10 Cocoa → invoke SweetChaliceNpc (craft Sweet Chalice)
  4. Spawn Dough King bằng Sweet Chalice (CakePrinceSpawner)
  5. Chưa có RedDoor → invoke CakeScientist + RaidsNpc mở dungeon (cần Red Key)
  6. Có RedDoor + có Red Key → tele đến cửa, equip Red Key mở
  7. Dough King spawn → bay lên đầu đánh (Fast Attack core xử lý)
  8. Lặp lại từ bước 3
]]

local DOUGH_WAIT_POS  = CFrame.new(-1943.676513671875, 251.5095672607422, -12337.880859375)
local COCOA_FARM_POS  = CFrame.new(402.7189025878906, 81.06050109863281, -12259.54296875)
local RED_DOOR_CF     = CFrame.new(-2681.97998, 64.3921585, -12853.7363,
    0.149007782, -1.87902192e-08, 0.98883605,
    3.60619588e-08, 1, 1.35681812e-08,
   -0.98883605, 3.36376011e-08, 0.149007782)

local function RunDoughKingChain()
    local char = LocalPlayer.Character; if not char then return end
    local plrRoot = char:FindFirstChild("HumanoidRootPart"); if not plrRoot then return end

    -- Bước 1: Chưa có God's Chalice / Sweet Chalice → skip về Chest farm
    -- Không farm Elite Hunter — chờ nhặt từ rương tự nhiên
    if not GetBP("God's Chalice") and not GetBP("Sweet Chalice") then
        _G.IsAttackingBoss = false
        StatusLabel.Text = "Dough King: Chưa có God's Chalice, farm Chest chờ..."
        StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        return  -- trả về main loop → xuống Auto Chest
    end

    -- Bước 2: Cần Conjured Cocoa ≥ 10 để craft
    local cocoaCount = GetM("Conjured Cocoa")
    if cocoaCount < 10 and not GetBP("Sweet Chalice") then
        local cocoaMob = GetConnectionEnemies({"Cocoa Warrior", "Chocolate Bar Battler"})
        if cocoaMob then
            StatusLabel.Text = string.format("Dough King: Farm Cocoa (%d/10)...", cocoaCount)
            StatusLabel.TextColor3 = Color3.fromRGB(210, 105, 30)
            _G.IsAttackingBoss = true
            PositionOnBoss(cocoaMob)
        else
            _G.IsAttackingBoss = false
            Teleport(COCOA_FARM_POS)
        end
        return
    end

    -- Bước 3: Craft Sweet Chalice từ God's Chalice + Cocoa
    if GetBP("God's Chalice") and cocoaCount >= 10 then
        StatusLabel.Text = "Dough King: Đang craft Sweet Chalice..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
        replicated.Remotes.CommF_:InvokeServer("SweetChaliceNpc")
        task.wait(1)
        return  -- chờ vòng lặp tiếp theo sync Sweet Chalice từ server
    end

    -- Bước 4: Spawn lại Dough King bằng Sweet Chalice
    if GetBP("Sweet Chalice") then
        replicated.Remotes.CommF_:InvokeServer("CakePrinceSpawner", true)
        task.wait(0.5)
    end

    -- Bước 5: Mở dungeon nếu chưa có RedDoor
    local cakeLoaf = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("CakeLoaf")
    if cakeLoaf and not cakeLoaf:FindFirstChild("RedDoor") then
        if GetBP("Red Key") then
            StatusLabel.Text = "Dough King: Đang mở dungeon..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            replicated.Remotes.CommF_:InvokeServer("CakeScientist", "Check")
            replicated.Remotes.CommF_:InvokeServer("RaidsNpc", "Check")
            task.wait(1)
        end
        return
    end

    -- Bước 6: Có RedDoor → tele vào dùng Red Key
    if cakeLoaf and cakeLoaf:FindFirstChild("RedDoor") and GetBP("Red Key") then
        local dist = (plrRoot.CFrame.Position - RED_DOOR_CF.Position).Magnitude
        if dist > 5 then
            StatusLabel.Text = "Dough King: Đang vào cửa đỏ..."
            StatusLabel.TextColor3 = Color3.fromRGB(200, 50, 50)
            Teleport(RED_DOOR_CF)
            return
        else
            EquipWeapon("Red Key")
            task.wait(0.5)
        end
    end

    -- Bước 7: Dough King đã spawn → bay lên đầu, Fast Attack lo phần còn lại
    local doughKing = GetConnectionEnemies("Dough King")
    if doughKing then
        StatusLabel.Text = "Dough King: Đang đánh Boss!!!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 200)
        _G.IsAttackingBoss = true
        PositionOnBoss(doughKing)
        return
    end

    -- Không có boss, không có gì để làm → chờ tại vị trí
    _G.IsAttackingBoss = false
    StatusLabel.Text = "Dough King: Chờ boss spawn..."
    StatusLabel.TextColor3 = Color3.fromRGB(150, 50, 255)
    Teleport(DOUGH_WAIT_POS)
    task.wait(1)
end

