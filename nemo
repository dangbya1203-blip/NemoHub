        Gold    = { fill = Color3.fromRGB(255, 200,  30), outline = Color3.fromRGB(160, 110,  0) },
        Silver  = { fill = Color3.fromRGB(210, 210, 210), outline = Color3.fromRGB(130, 130, 130) },
        Diamond = { fill = Color3.fromRGB( 80, 230, 255), outline = Color3.fromRGB(  0, 140, 190) },
    }
    local function getFlowerColor(obj)
        if obj:IsA("BasePart") then return { fill = obj.Color, outline = Color3.fromRGB(0, 0, 0) } end
        local part = obj:FindFirstChildWhichIsA("BasePart")
        if part then return { fill = part.Color, outline = Color3.fromRGB(0, 0, 0) } end
        return { fill = Color3.fromRGB(200, 200, 200), outline = Color3.fromRGB(0, 0, 0) }
    end
    local function getChestColor(name)
        if string.find(name, "Gold",    1, true) then return CHEST_COLOR.Gold
        elseif string.find(name, "Diamond", 1, true) then return CHEST_COLOR.Diamond
        else return CHEST_COLOR.Silver end
    end

    local FRUIT_BLACKLIST = {
        ["Apple"] = true, ["Banana"] = true, ["Pineapple"] = true,
        ["Orange"] = true, ["Lemon"] = true, ["Berry"] = true,
    }

    local function createESP(target, category, overrideColor)
        local rootPart
        if target:IsA("Model") then
            rootPart = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")
        elseif target:IsA("BasePart") then rootPart = target
        elseif target:IsA("Tool") then rootPart = target:FindFirstChildWhichIsA("BasePart")
        end
        if not rootPart then return nil end
        local col       = overrideColor or ESP_COLOR[category]
        local TargetGui = CoreGui
        pcall(function() TargetGui = gethui() or TargetGui end)
        local bb = Instance.new("BillboardGui")
        bb.Name                  = "NemoESP_" .. category
        bb.Adornee               = rootPart
        bb.AlwaysOnTop           = true
        bb.Size                  = UDim2.new(0, 130, 0, 42)
        bb.StudsOffsetWorldSpace = Vector3.new(0, 3.2, 0)
        bb.LightInfluence        = 0
        bb.Parent                = TargetGui
        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size               = UDim2.new(1, 0, 1, 0)
        lbl.TextColor3         = col.fill
        lbl.Font               = Enum.Font.GothamBold
        lbl.TextSize           = 13
        lbl.RichText           = true
        lbl.TextScaled         = false
        lbl.TextXAlignment     = Enum.TextXAlignment.Center
        lbl.Text               = "..."
        lbl.Parent             = bb
        local stroke = Instance.new("UIStroke")
        stroke.Color     = Color3.fromRGB(0, 0, 0)
        stroke.Thickness = 1.5
        stroke.Parent    = lbl
        return { billboard = bb, label = lbl, root = rootPart }
    end

    local function destroyEntry(entry)
        if not entry then return end
        pcall(function()
            if entry.billboard then
                entry.billboard.Enabled = false
                if entry.label then
                    entry.label.Visible = false
                    local stroke = entry.label:FindFirstChildOfClass("UIStroke")
                    if stroke then stroke.Enabled = false; stroke:Destroy() end
                end
                entry.billboard.Parent = nil
                entry.billboard:Destroy()
            end
        end)
    end

    local function clearCategory(category)
        local cat = _G.ESP_Instances[category]
        if not cat then return end
        for _, entry in pairs(cat) do destroyEntry(entry) end
        _G.ESP_Instances[category] = {}
    end

    local function getTeamTag(player)
        if player.Team then
            local r = math.floor(player.TeamColor.Color.R * 255)
            local g = math.floor(player.TeamColor.Color.G * 255)
            local b = math.floor(player.TeamColor.Color.B * 255)
            return string.format(" <font color=\"#%02X%02X%02X\">[%s]</font>", r, g, b, player.Team.Name)
        end
        return ""
    end

    local function getRootPos(entry)
        if entry and entry.root and entry.root.Parent then return entry.root.Position end
        return nil
    end

    task.spawn(function()
        while task.wait(1) do
            pcall(function()
                if _G.ESP_Players then
                    local cat    = _G.ESP_Instances.Players
                    local active = {}
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= Player and p.Character then
                            local key = tostring(p.UserId)
                            active[key] = true
                            if not cat[key] then
                                local entry = createESP(p.Character, "Players")
                                if entry then entry.playerRef = p; cat[key] = entry end
                            else
                                local entry   = cat[key]
                                local newRoot = p.Character:FindFirstChild("HumanoidRootPart")
                                if newRoot and entry.root ~= newRoot then
                                    entry.root = newRoot
                                    pcall(function() entry.billboard.Adornee = newRoot end)
                                end
                            end
                        end
                    end
                    for key, entry in pairs(cat) do
                        if not active[key] then destroyEntry(entry); cat[key] = nil end
                    end
                end
                if _G.ESP_Chests then
                    local cat    = _G.ESP_Instances.Chests
                    local active = {}
                    local function scanChests(parent)
                        if not parent then return end
                        for _, obj in ipairs(parent:GetChildren()) do
                            if string.find(obj.Name, "Chest", 1, true) then
                                local key = obj; active[key] = true
                                if not cat[key] then
                                    local entry = createESP(obj, "Chests", getChestColor(obj.Name))
                                    if entry then entry.displayName = obj.Name; cat[key] = entry end
                                end
                            end
                        end
                    end
                    scanChests(workspace:FindFirstChild("ChestModels"))
                    pcall(function() scanChests(workspace:FindFirstChild("Map")) end)
                    for key, entry in pairs(cat) do
                        if not active[key] then destroyEntry(entry); cat[key] = nil end
                    end
                end
                if _G.ESP_Fruits then
                    local cat    = _G.ESP_Instances.Fruits
                    local active = {}
                    for _, obj in ipairs(workspace:GetChildren()) do
                        local isServerFruit = string.find(obj.Name, "Fruit", 1, true) and not FRUIT_BLACKLIST[obj.Name]
                        local isDropFruit   = obj:IsA("Tool") and obj.ToolTip == "Blox Fruit"
                        if isServerFruit or isDropFruit then
                            local key = obj; active[key] = true
                            if not cat[key] then
                                local entry = createESP(obj, "Fruits")
                                if entry then entry.displayName = obj.Name; cat[key] = entry end
                            end
                        end
                    end
                    for key, entry in pairs(cat) do
                        if not active[key] then destroyEntry(entry); cat[key] = nil end
                    end
                end
                if _G.ESP_Flowers then
                    local cat    = _G.ESP_Instances.Flowers
                    local active = {}
                    local FLOWER_NAMES = { ["Flower1"] = true, ["Flower2"] = true }
                    local function scanFlowers(parent)
                        if not parent then return end
                        for _, obj in ipairs(parent:GetChildren()) do
                            if FLOWER_NAMES[obj.Name] then
                                local key = obj; active[key] = true
                                if not cat[key] then
                                    local entry = createESP(obj, "Flowers", getFlowerColor(obj))
                                    if entry then entry.displayName = obj.Name; cat[key] = entry end
                                end
                            end
                        end
                    end
                    scanFlowers(workspace)
                    for key, entry in pairs(cat) do
                        if not active[key] then destroyEntry(entry); cat[key] = nil end
                    end
                end
            end)
        end
    end)

    local function updateESPLabel(myPos, category, defaultName)
        for _, entry in pairs(_G.ESP_Instances[category]) do
            pcall(function()
                local pos = getRootPos(entry)
                if not pos then return end
                entry.label.Text = string.format(
                    "<b>%s</b>\n<font color=\"#DDDDDD\">[%dm]</font>",
                    entry.displayName or defaultName,
                    math.floor((myPos - pos).Magnitude)
                )
            end)
        end
    end

    RunService.RenderStepped:Connect(function()
        if not _G.ESP_Players and not _G.ESP_Chests and not _G.ESP_Fruits and not _G.ESP_Flowers then return end
        local char   = Player.Character
        local myRoot = char and char:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        local myPos = myRoot.Position
        if _G.ESP_Players then
            for _, entry in pairs(_G.ESP_Instances.Players) do
                pcall(function()
                    local pos = getRootPos(entry)
                    if not pos then return end
                    local p    = entry.playerRef
                    local dist = math.floor((myPos - pos).Magnitude)
                    local name = (p and p.DisplayName) or "?"
                    local team = p and getTeamTag(p) or ""
                    entry.label.Text = string.format(
                        "<b>%s</b>%s\n<font color=\"#DDDDDD\">[%dm]</font>", name, team, dist)
                end)
            end
        end
        if _G.ESP_Chests  then updateESPLabel(myPos, "Chests",  "Chest")  end
        if _G.ESP_Fruits  then updateESPLabel(myPos, "Fruits",  "Fruit")  end
        if _G.ESP_Flowers then updateESPLabel(myPos, "Flowers", "Flower") end
    end)

    Tabs.Esp:AddSection("Điều Khiển ESP")
    Tabs.Esp:AddToggle("EspPlayers", {
        Title       = "ESP Người Chơi",
        Description = "Hiển thị tên, team và khoảng cách",
        Default     = false,
        Callback    = function(Value)
            _G.ESP_Players = Value
            if not Value then clearCategory("Players") end
        end
    })
    Tabs.Esp:AddToggle("EspChests", {
        Title       = "ESP Rương Kho Báu",
        Description = "Hiển thị toàn bộ rương kho báu trên map",
        Default     = false,
        Callback    = function(Value)
            _G.ESP_Chests = Value
            if not Value then clearCategory("Chests") end
        end
    })
    Tabs.Esp:AddToggle("EspFruits", {
        Title       = "ESP Trái Ác Quỷ",
        Description = "Bắt trái server spawn và trái người chơi drop",
        Default     = false,
        Callback    = function(Value)
            _G.ESP_Fruits = Value
            if not Value then clearCategory("Fruits") end
        end
    })
    Tabs.Esp:AddToggle("EspFlowers", {
        Title       = "ESP Hoa",
        Description = "Hiển thị Flower 1 / 2 toàn map",
        Default     = false,
        Callback    = function(Value)
            _G.ESP_Flowers = Value
            if not Value then clearCategory("Flowers") end
        end
    })
    Tabs.Esp:AddToggle("AutoCollectFruit", {
        Title       = "Tự Động Nhặt Trái Ác Quỷ",
        Description = "Tự bay đến trái được phát hiện bởi ESP và nhặt (yêu cầu ESP Trái bật)",
        Default     = false,
        Callback    = function(Value) _G.AutoCollectFruit = Value end
    })

    task.spawn(function()
        while task.wait(0.5) do
            if _G.AutoCollectFruit and _G.ESP_Fruits then
                pcall(function()
                    local char  = Player.Character
                    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
                    if not myHRP then return end
                    local closestEntry, closestDist = nil, 60
                    for _, entry in pairs(_G.ESP_Instances.Fruits) do
                        local pos = getRootPos(entry)
                        if pos then
                            local d = (myHRP.Position - pos).Magnitude
                            if d < closestDist then closestDist = d; closestEntry = entry end
                        end
                    end
                    if closestEntry then
                        local pos = getRootPos(closestEntry)
                        if pos then
                            local TweenSpeed3 = 300
                            local dist3 = (myHRP.Position - pos).Magnitude
                            local info3 = TweenInfo.new(dist3 / TweenSpeed3, Enum.EasingStyle.Linear)
                            local tw3 = TweenService:Create(myHRP, info3, {CFrame = CFrame.new(pos)})
                            tw3:Play()
                            local wt = 0
                            repeat
                                task.wait(0.1); wt = wt + 0.1
                                local h2 = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                                if h2 and (h2.Position - pos).Magnitude <= 8 then break end
                            until wt >= 4
                        end
                    end
                end)
            end
        end
    end)
end

