local function main()
    AutoSelectTeam()

    while getgenv().NemoRunning do
        local char = LocalPlayer.Character
        local RootPart = char and char:FindFirstChild("HumanoidRootPart")
        if not RootPart then task.wait(1); continue end

        -- [ƯU TIÊN 1] Lụm Trái
        if CollectFruit then
            local fruits = GetDroppedFruits()
            if #fruits > 0 then
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Phát hiện Trái! Đang lụm..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                GrabFruit(RootPart, fruits[1]); task.wait(0.3); continue
            end
        end

        -- [ƯU TIÊN 2] Dough King (Sea 3)
        if AutoDoughKing and IsInSea("sea3") then
            local hasChalice = GetBP("God's Chalice") or GetBP("Sweet Chalice")
            local doughKingActive = GetConnectionEnemies("Dough King") ~= nil
            if hasChalice or doughKingActive then RunDoughKingChain(); task.wait(0.05); continue end
        end

        -- [ƯU TIÊN 3] Darkbeard (Sea 2)
        if AutoDarkbeard and IsInSea("sea2") then
            local darkbeard = GetDarkbeard()
            if darkbeard then
                _G.IsAttackingBoss = true
                StatusLabel.Text = "Status: Đánh Darkbeard!!!"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                PositionOnBoss(darkbeard); task.wait(0.05); continue
            elseif HasFistOfDarkness() then
                _G.IsAttackingBoss = false
                -- Retry activate mỗi 5s cho đến khi boss spawn hoặc mất fist
                local retryTick = 0
                local deadline = tick() + 60  -- chờ tối đa 60s
                while tick() < deadline and getgenv().NemoRunning do
                    if GetDarkbeard() or not HasFistOfDarkness() then break end
                    if tick() - retryTick >= 5 then
                        retryTick = tick()
                        ActivateFistAtAltar()
                    end
                    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                    if hum then hum.Jump = true end
                    task.wait(0.5)
                end
                continue
            end
        end

        -- [ƯU TIÊN 4] Auto Chest (Có Lô 15 rương & Fix Smooth TP)
        if ShouldBreakChest() then task.wait(); continue end
        _G.IsAttackingBoss = false
        StatusLabel.Text = "Status: Auto Chest (" .. (InstantTP and "Instant" or "Smooth TP") .. ")"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)

        local Chests = getChestsSorted()
        if #Chests == 0 then
            StatusLabel.Text = "Status: Không có rương, chờ 3s rồi hop..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            local antiKickEnd = tick() + 3
            while tick() < antiKickEnd and getgenv().NemoRunning do
                if ShouldBreakChest() then break end
                pcall(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new(math.random(200, 600), math.random(200, 500))) end)
                task.wait(0.8)
            end
            if ShouldBreakChest() or not getgenv().NemoRunning then task.wait(); continue end
            HopServer(); task.wait(3); continue
        end

        -- Lô rương (Batching): Lướt nhanh rồi nghỉ 1 nhịp check Radar
        local batchSize = InstantTP and 15 or 5 
        local count = 0

        for _, Chest in ipairs(Chests) do
            if not getgenv().NemoRunning then break end
            if count >= batchSize then break end 

            char = LocalPlayer.Character; RootPart = char and char:FindFirstChild("HumanoidRootPart")
            if not RootPart then break end
            if Chest and Chest.Parent and Chest:FindFirstChild("TouchInterest") then
                TouchChest(RootPart, Chest)
                IgnoredChests[Chest] = tick()
                count = count + 1
                task.wait(0.15)
                if ShouldBreakChest() then break end
            end
        end
        task.wait()
    end
end

-- Khởi động Main Loop
main()
