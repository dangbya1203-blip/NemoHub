local CombatModule = {}

-- Dùng VirtualInputManager bấm phím skill thật (học từ BoneHub Useskills)
local function pressKey(key)
    VIM:SendKeyEvent(true,  key, false, game)
    VIM:SendKeyEvent(false, key, false, game)
end

function CombatModule.UseSkill(weapon, key)
    local char = getChar()
    if not char then return end
    -- Equip đúng loại vũ khí trước
    local toolTip = weapon  -- "Melee", "Sword", "Blox Fruit", "Gun"
    for _, tool in ipairs(Plr.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.ToolTip == toolTip then
            char.Humanoid:EquipTool(tool)
            break
        end
    end
    task.wait(0.05)
    pressKey(key)
end

function CombatModule.FastAttack()
    local char = getChar()
    if not char then return end
    if not char:FindFirstChildOfClass("Tool") then return end

    local mobs = MobModule.GetAlive(nil)
    if #mobs == 0 then return end

    local targetParts = {}
    for _, mob in ipairs(mobs) do
        local head = mob:FindFirstChild("Head")
        if head then table.insert(targetParts, { mob, head }) end
    end
    if #targetParts == 0 then return end

    pcall(function()
        Remotes.RegisterAttack:FireServer(CFG.AttackRate)
        Remotes.RegisterHit:FireServer(targetParts[1][2], targetParts)
    end)
end

--==============================================================================
-- SECTION 10 : __NAMECALL HOOK  (học từ BoneHub — MousePos injection)
--   Khi bật, mọi skill:FireServer() sẽ tự inject vị trí của mob đích
--   vào tham số thứ 2 (MousePos) — aimbot không cần biết tên remote.
--==============================================================================
local NamecallModule = {}
NamecallModule.enabled = false
NamecallModule._orig   = nil

local _MousePos = Vector3.zero  -- cập nhật liên tục bên dưới

function NamecallModule.Enable()
    if NamecallModule._orig then return end  -- đã hook rồi
    local gg  = getrawmetatable(game)
    local old = gg.__namecall
    NamecallModule._orig = old
    setreadonly(gg, false)

    gg.__namecall = newcclosure(function(...)
        local method = getnamecallmethod()
        local args   = { ... }
        if NamecallModule.enabled and tostring(method) == "FireServer" then
            if tostring(args[1]) == "RemoteEvent" then
                -- Inject MousePos vào args[2] nếu đang farm/aura
                args[2] = _MousePos
                return old(unpack(args))
            end
        end
        return old(...)
    end)

    setreadonly(gg, true)
end

function NamecallModule.Disable()
    NamecallModule.enabled = false
    -- Không unhook vì không thể restore an toàn — chỉ tắt flag
end

-- Cập nhật _MousePos về HRP của mob gần nhất
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if NamecallModule.enabled then
                local mobs = MobModule.GetAlive(nil)
                if #mobs > 0 then
                    local hrp = mobs[1]:FindFirstChild("HumanoidRootPart")
                    if hrp then _MousePos = hrp.Position end
                end
            end
        end)
    end
end)

