local function AutoSelectTeam()
    local function hasTeam()
        if LocalPlayer:FindFirstChild("Main") then return true end
        local t = LocalPlayer.Team
        return t ~= nil and t.Name ~= "Neutral" and t.Name ~= ""
    end
    if hasTeam() then return end
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    local function trySelect()
        pcall(function() RS.Remotes.CommF_:InvokeServer("SetTeam", JoinTeam) end)
        pcall(function() RS.Remotes.CommF_:InvokeServer("SelectTeam", JoinTeam) end)
        pcall(function()
            local mm = PlayerGui:FindFirstChild("Main (minimal)")
            if not mm then return end
            local ct = mm:FindFirstChild("ChooseTeam", true)
            if not ct or not ct.Visible then return end
            local btn
            for _, obj in ipairs(ct:GetDescendants()) do
                if (obj:IsA("TextButton") or obj:IsA("ImageButton"))
                and (string.find(string.lower(obj.Name),string.lower(JoinTeam))
                  or (obj.Parent and string.find(string.lower(obj.Parent.Name),string.lower(JoinTeam))))
                then btn = obj; break end
            end
            if btn then
                if getconnections then
                    for _, conn in ipairs(getconnections(btn.Activated)) do pcall(conn.Function) end
                else
                    local vim = game:GetService("VirtualInputManager")
                    local pos = btn.AbsolutePosition + btn.AbsoluteSize / 2
                    vim:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 1)
                    task.wait(0.05)
                    vim:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 1)
                end
            end
        end)
    end
    local last = 0
    while not hasTeam() and getgenv().NemoRunning do
        if tick() - last >= 0.5 then trySelect(); last = tick() end
        task.wait()
    end
end

-- === CHEST SORTING ===
local function getChestsSorted()
    -- Scan workspace on first run
    if FirstRun then
        FirstRun = false
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Part") and obj.Name:find("Chest") then addChest(obj) end
        end
    end
    -- Rebuild clean list
    local cleaned = {}
    for _, c in ipairs(ChestList) do
        if c and c.Parent and ChestSet[c] then table.insert(cleaned, c) end
    end
    ChestList = cleaned
    -- Rebuild set
    ChestSet = {}
    for _, c in ipairs(ChestList) do ChestSet[c] = true end

    local now = tick()
    local char = LocalPlayer.Character
    local RP   = char and char:FindFirstChild("HumanoidRootPart")
    local out  = {}
    for _, c in ipairs(ChestList) do
        if c:IsA("BasePart") and c:FindFirstChild("TouchInterest") then
            local lt = IgnoredChests[c]
            if not lt or (now - lt > CHEST_IGNORE_TIME) then
                table.insert(out, c)
            end
        end
    end
    if RP then
        local rx,ry,rz = RP.Position.X, RP.Position.Y, RP.Position.Z
        table.sort(out, function(A,B)
            local ax,ay,az = A.Position.X-rx, A.Position.Y-ry, A.Position.Z-rz
            local bx,by,bz = B.Position.X-rx, B.Position.Y-ry, B.Position.Z-rz
            return ax*ax+ay*ay+az*az < bx*bx+by*by+bz*bz
        end)
    end
    return out
end

-- === SERVER HOP ===
local _hopFailCount = 0
local function HopServer()
    StatusLabel.Text = "Status: Hopping server..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    VisitedServers[game.JobId] = true

    local function fetchServers(cursor)
        local url = "https://games.roblox.com/v1/games/"..PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
        if cursor and cursor ~= "" then url = url .. "&cursor=" .. cursor end
        local ok, res = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
        if ok and res and res.data then return res.data, res.nextPageCursor end
        return nil, nil
    end
    local function findBest(servers)
        for _, s in ipairs(servers) do
            local playing = s.playing or 0
            local maxP    = s.maxPlayers or 0
            if s.id ~= game.JobId and not VisitedServers[s.id]
            and playing > 0 and (maxP - playing) >= 1 then
                return s
            end
        end
        return nil
    end

    local allServers = {}
    local cursor = ""
    for _ = 1, 3 do
        local page, nxt = fetchServers(cursor)
        if not page then break end
        for _, s in ipairs(page) do table.insert(allServers, s) end
        if not nxt or nxt == "" then break end
        cursor = nxt
    end

    local best = findBest(allServers)

    -- Reset visited once on first full-list miss, not every fail
    if not best then
        _hopFailCount = _hopFailCount + 1
        if _hopFailCount >= 2 then
            _hopFailCount = 0
            VisitedServers = { [game.JobId] = true }
            best = findBest(allServers)
        end
    else
        _hopFailCount = 0
    end

    if best then
        VisitedServers[best.id] = true
        StatusLabel.Text = string.format("Status: Hopping → %d/%d players", best.playing or 0, best.maxPlayers or 0)
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        TeleportService:TeleportToPlaceInstance(PlaceId, best.id, LocalPlayer)
    else
        local waitTime = math.min(5 * _hopFailCount, 30)
        StatusLabel.Text = "Status: No server found, retrying in " .. waitTime .. "s..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        task.wait(math.max(waitTime, 5))
    end
end

-- === CHEST INTERACTION ===
local function jumpIntoChest(RP, Chest, maxA)
    maxA = maxA or 4
    for i = 1, maxA do
        if not Chest or not Chest.Parent or not getgenv().NemoRunning then return end
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or hum.Health <= 0 or not root then return end
        local angle = (i-1) * (math.pi*2/maxA) + math.random()*0.3
        local ad = hrand(1.5, 2.5)
        root.CFrame = Chest.CFrame * CFrame.new(math.cos(angle)*ad, 1.5, math.sin(angle)*ad)
        RunService.Heartbeat:Wait()
        pcall(function() root.AssemblyLinearVelocity = (Chest.Position - root.Position).Unit * 28 end)
        task.wait(0.06)
        root.CFrame = Chest.CFrame * CFrame.new(0, 0.3, 0)
        pcall(function()
            if firetouchinterest then
                firetouchinterest(root, Chest, 0); task.wait(hrand(0.06,0.10)); firetouchinterest(root, Chest, 1)
            end
        end)
        if not Chest or not Chest.Parent then return end
    end
end

local function TouchChest(RP, Chest)
    if not Chest or not Chest.Parent then return end
    if InstantTP then
        RP.CFrame = jitterCF(Chest.CFrame * CFrame.new(0, 0.5, 0))
        local fired = false
        pcall(function()
            if firetouchinterest then
                firetouchinterest(RP, Chest, 0)
                task.wait(hrand(0.05, 0.08))
                firetouchinterest(RP, Chest, 1)
                fired = true
            end
        end)
        if not fired then jumpIntoChest(RP, Chest, 2) end
    else
        Teleport(Chest.CFrame)
        pcall(function()
            if firetouchinterest then
                firetouchinterest(RP, Chest, 0); task.wait(0.05); firetouchinterest(RP, Chest, 1)
            end
        end)
        RunService.Heartbeat:Wait()
    end
end

-- === FRUIT COLLECTION ===
local function GrabFruit(fruit)
    if not fruit or not fruit.Parent then return end
    local handle = fruit:FindFirstChild("Handle")
    if not handle then return end
    local fc = LocalPlayer.Character
    local fr = fc and fc:FindFirstChild("HumanoidRootPart")
    if not fr then return end
    local dist = (fr.Position - handle.Position).Magnitude
    if dist > 800 then return end
    -- Instant TP thay vì tween — fruit despawn nhanh
    fr.CFrame = jitterCF(handle.CFrame * CFrame.new(0, 0.5, 0), 0.3)
    task.wait(0.05)
    -- Re-fetch sau TP
    fc = LocalPlayer.Character
    fr = fc and fc:FindFirstChild("HumanoidRootPart")
    if not fr then return end
    for _ = 1, 2 do
        if not fruit or not fruit.Parent then break end
        pcall(function()
            if firetouchinterest then
                firetouchinterest(fr, handle, 0)
                task.wait(0.05)
                firetouchinterest(fr, handle, 1)
            end
        end)
        task.wait(hrand(0.08, 0.12))
    end
    StoreFruit()
end

-- === MAIN LOOP ===
local function main()
    AutoSelectTeam()
    while getgenv().NemoRunning do
        local char    = LocalPlayer.Character
        local RootPart = char and char:FindFirstChild("HumanoidRootPart")
        if not RootPart then task.wait(1); continue end

        -- Fruit priority
        if CollectFruit then
            local fruits = GetDroppedFruits()
            if #fruits > 0 then
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Fruit detected! Collecting..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                GrabFruit(fruits[1])
                continue
            end
        end

        _G.IsAttackingBoss = false

        local Chests = getChestsSorted()
        local totalChests = #Chests

        if totalChests == 0 then
            StatusLabel.Text = "Status: No chests found, hopping..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            HopServer()
            continue
        end

        local mode = InstantTP and "Instant" or "Smooth"
        StatusLabel.Text = string.format("Status: Auto Chest [%s] | Remaining: %d", mode, totalChests)
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)

        for _, Chest in ipairs(Chests) do
            if not getgenv().NemoRunning then break end
            char = LocalPlayer.Character
            RootPart = char and char:FindFirstChild("HumanoidRootPart")
            if not RootPart then break end
            if Chest and Chest.Parent and Chest:FindFirstChild("TouchInterest") then
                TouchChest(RootPart, Chest)
                IgnoredChests[Chest] = tick()
                task.wait(hrand(0.05, 0.08))
                if CollectFruit and #GetDroppedFruits() > 0 then break end
            end
        end
        task.wait()
    end
end

main()
