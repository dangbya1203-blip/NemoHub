              and g.Main:FindFirstChild("Quest")
              and g.Main.Quest.Visible
end

function QuestModule.GetActiveTitle()
    local label = safeFind(Plr, "PlayerGui", "Main", "Quest", "Container", "QuestTitle", "Title")
    return label and label.Text or ""
end

function QuestModule.Abandon()
