local function jumpIntoChest(RootPart, Chest, maxAttempts)
    maxAttempts = maxAttempts or 4
    for attempt = 1, maxAttempts do
        if not Chest or not Chest.Parent or not getgenv().NemoRunning then return end
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or hum.Health <= 0 or not root then return end
        local angle = (attempt - 1) * (math.pi * 2 / maxAttempts) + math.random() * 0.3
        local approachDist = hrand(1.5, 2.5)
        root.CFrame = Chest.CFrame * CFrame.new(math.cos(angle) * approachDist, 1.5, math.sin(angle) * approachDist)
        RunService.Heartbeat:Wait()
        hum.Jump = true
        pcall(function() root.AssemblyLinearVelocity = (Chest.Position - root.Position).Unit * 28 end); task.wait(0.06)
        root.CFrame = Chest.CFrame * CFrame.new(0, 0.3, 0)
        pcall(function() if firetouchinterest then firetouchinterest(root, Chest, 0); task.wait(hrand(0.06, 0.10)); firetouchinterest(root, Chest, 1) end end)
        if not Chest or not Chest.Parent then return end
    end
end

local function TouchChest(RootPart, Chest)
    if InstantTP then
        RootPart.CFrame = jitterCF(Chest.CFrame * CFrame.new(0, 0.5, 0))
        local fired = false
        pcall(function()
            if firetouchinterest then
                firetouchinterest(RootPart, Chest, 0)
                task.wait(hrand(0.1, 0.15)) -- ANTI-GHOST TOUCH
                firetouchinterest(RootPart, Chest, 1)
                fired = true
            end
        end)
        if not fired then jumpIntoChest(RootPart, Chest) end
    else
        Teleport(Chest.CFrame)
        pcall(function()
            if firetouchinterest then
                firetouchinterest(RootPart, Chest, 0)
                task.wait(0.05)
                firetouchinterest(RootPart, Chest, 1)
            end
        end)
        RunService.Heartbeat:Wait()
    end
end

local function GrabFruit(RootPart, fruit)
    local handle = fruit:FindFirstChild("Handle")
    if not handle then return end
    local targetCF = jitterCF(handle.CFrame, 0.3)
    SafeTweenTP(targetCF)
    local freshChar = LocalPlayer.Character
    local freshRoot = freshChar and freshChar:FindFirstChild("HumanoidRootPart")
    if not freshRoot then return end
    pcall(function() if firetouchinterest then firetouchinterest(freshRoot, handle, 0); task.wait(hrand(0.08, 0.15)); firetouchinterest(freshRoot, handle, 1) end end)
    task.wait(hrand(0.4, 0.7))
    StoreFruit()
end

local function ShouldBreakChest()
    if CollectFruit and #GetDroppedFruits() > 0 then return true end
    return false
end

local function main()
    AutoSelectTeam()

    while getgenv().NemoRunning do
        local char = LocalPlayer.Character
        local RootPart = char and char:FindFirstChild("HumanoidRootPart")
        if not RootPart then task.wait(1); continue end

        -- [ƯU TIÊN 1] Lụm Trái
        if CollectFruit then
            local fruits = GetDroppedFruits()
            if #fruits > 0 then
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Phát hiện Trái! Đang lụm..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                GrabFruit(RootPart, fruits[1]); task.wait(0.3); continue
            end
        end


        -- [ƯU TIÊN 4] Auto Chest (Có Lô 15 rương & Fix Smooth TP)
        if ShouldBreakChest() then task.wait(); continue end
        _G.IsAttackingBoss = false
        StatusLabel.Text = "Status: Auto Chest (" .. (InstantTP and "Instant" or "Smooth TP") .. ")"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)

        local Chests = getChestsSorted()
        if #Chests == 0 then
            StatusLabel.Text = "Status: Không có rương, chờ 3s rồi hop..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            local antiKickEnd = tick() + 3
            while tick() < antiKickEnd and getgenv().NemoRunning do
                if ShouldBreakChest() then break end
                pcall(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new(math.random(200, 600), math.random(200, 500))) end)
                task.wait(0.8)
            end
            if ShouldBreakChest() or not getgenv().NemoRunning then task.wait(); continue end
            HopServer(); task.wait(3); continue
        end

        -- Lô rương (Batching): Lướt nhanh rồi nghỉ 1 nhịp check Radar
        local batchSize = InstantTP and 15 or 5 
        local count = 0

        for _, Chest in ipairs(Chests) do
            if not getgenv().NemoRunning then break end
            if count >= batchSize then break end 

            char = LocalPlayer.Character; RootPart = char and char:FindFirstChild("HumanoidRootPart")
            if not RootPart then break end
            if Chest and Chest.Parent and Chest:FindFirstChild("TouchInterest") then
                TouchChest(RootPart, Chest)
                IgnoredChests[Chest] = tick()
                count = count + 1
                task.wait(0.15)
                if ShouldBreakChest() then break end
            end
        end
        task.wait()
    end
end

-- Khởi động Main Loop
main()
