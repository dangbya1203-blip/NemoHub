-- Loop Auto Farm & Gom Quái
task.spawn(function()
    while task.wait(0.1) do
        if AutoFarmLevelEnabled then
            local QuestData = GetQuestData()
            
            if QuestData then
                local playerGui = Plr:FindFirstChild("PlayerGui")
                
                -- Hủy quest sai
                if HasQuest() then
                    local currentQuestText = playerGui.Main.Quest.Container.QuestTitle.Title.Text
                    if not string.find(currentQuestText, QuestData.MobName) then
                        ReplicatedStorage.Remotes.CommF_:InvokeServer("AbandonQuest")
                        task.wait(0.5)
                    end
                end

                -- Nhận quest
                if not HasQuest() then
                    TweenObject(Plr.Character.HumanoidRootPart, QuestData.NPCPos, 300)
                    if (Plr.Character.HumanoidRootPart.Position - QuestData.NPCPos.Position).Magnitude < 10 then
                        ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", QuestData.QuestName, QuestData.QuestNum)
                    end
                else
                    -- Đi farm quái
                    local character = Plr.Character
                    if character and character:FindFirstChild("HumanoidRootPart") then
                        
                        -- Chống rơi
                        if not character.HumanoidRootPart:FindFirstChild("AutoFarmVelocity") then
                            local bv = Instance.new("BodyVelocity")
                            bv.Name = "AutoFarmVelocity"
                            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                            bv.Velocity = Vector3.new(0, 0, 0)
                            bv.Parent = character.HumanoidRootPart
                        end

                        local targetMob = nil
                        for _, v in pairs(Workspace.Enemies:GetChildren()) do
                            if v.Name == QuestData.MobName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                                targetMob = v
                                break
                            end
                        end

                        if targetMob then
                            local targetHRP = targetMob:FindFirstChild("HumanoidRootPart")
                            if targetHRP then
                                -- Bay lên đầu quái
                                TweenObject(character.HumanoidRootPart, targetHRP.CFrame * CFrame.new(0, 15, 0), 300)
                                -- Gom đúng loại quái nhiệm vụ
                                ExecuteBringMobs(QuestData.MobName)
                            end
                        end
                    end
                end
            end
        else
            -- Tắt Auto Farm: Hủy BodyVelocity cho rớt xuống đất
            if Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart") then
                local bv = Plr.Character.HumanoidRootPart:FindFirstChild("AutoFarmVelocity")
                if bv then bv:Destroy() end
            end
            
            -- Chạy Gom Quái thủ công nếu được bật riêng
            if BringMobsEnabled then
                local enemies = Workspace.Enemies:GetChildren()
                if #enemies > 0 then
                    ExecuteBringMobs(enemies[1].Name) -- Gom đại con quái đầu tiên thấy
                end
            end
        end
    end
end)

