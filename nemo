    local function getEffectiveTweenSpeed()
        if not _G._farmOnIsland then return 300 end
        if _G.AutoFarm and (_G.SpecialFarmMode == "Bone" or _G.SpecialFarmMode == "Katakuri") then
            return 800
        end
        return TweenSpeed
    end

    local function findNearestFarmGate(targetPos, playerPos)
        if #FARM_GATES == 0 then return nil end
        local bestGate, bestDist = nil, math.huge
        for _, gate in ipairs(FARM_GATES) do
            local d = (gate - targetPos).Magnitude
            if d < bestDist then bestDist = d; bestGate = gate end
        end
        if bestGate and bestDist < (targetPos - playerPos).Magnitude then
            return bestGate
        end
        return nil
    end

    local _isTeleporting = false

    local function stopPartTele()
        _isTeleporting = false
        pcall(function()
            local char = Player.Character
            if char and char:FindFirstChild("PartTele") then
                char.PartTele:Destroy()
            end
        end)
    end

    -- Cleanup PartTele khi chết
    Player.CharacterAdded:Connect(function(char)
        local hum = char:WaitForChild("Humanoid")
        hum.Died:Connect(stopPartTele)
    end)
    if Player.Character then
        local hum = Player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Died:Connect(stopPartTele) end
    end

    local function TweenPlayer(pos)
        pcall(function()
            local char = Player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not hrp then return end
            local dist = (hrp.Position - pos.Position).Magnitude
            if dist < 1 then return end
            local destChanged = not _lastTweenDest
                or (_lastTweenDest - pos.Position).Magnitude > 3
            local tweenDone = not _activeTween
                or _activeTween.PlaybackState ~= Enum.PlaybackState.Playing
            if not destChanged and not tweenDone then return end
            -- Cancel tween cũ
            if _activeTween and _activeTween.PlaybackState == Enum.PlaybackState.Playing then
                _activeTween:Cancel()
            end
            _lastTweenDest = pos.Position

            -- PartTele pattern từ Tiroreal: tween 1 Part CanCollide=true
            -- HRP follow theo → không xuyên tường/kẹt địa hình
            stopPartTele()
            local partTele = Instance.new("Part")
            partTele.Name        = "PartTele"
            partTele.Size        = Vector3.new(4, 1, 4)
            partTele.Anchored    = true
            partTele.CanCollide  = true
            partTele.Transparency = 1
            partTele.CFrame      = hrp.CFrame
            partTele.Parent      = char

            partTele:GetPropertyChangedSignal("CFrame"):Connect(function()
                if not _isTeleporting then return end
                task.wait()
                local c = Player.Character
                local h = c and c:FindFirstChild("HumanoidRootPart")
                if h and partTele.Parent then
                    h.CFrame = partTele.CFrame
                end
            end)

            _isTeleporting = true
            local speed = getEffectiveTweenSpeed()
            local info  = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
            _activeTween = TweenService:Create(partTele, info, {CFrame = pos})
            _activeTween:Play()
            _activeTween.Completed:Connect(function(state)
                if state == Enum.PlaybackState.Completed then
                    stopPartTele()
                end
            end)
        end)
    end

    local function NavigateTo(targetCF, questName, mobName)
        pcall(function()
            local char = Player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not hrp then return end
            if not targetCF then return end
            local dist = (hrp.Position - targetCF.Position).Magnitude
            if dist < 10 then return end
            _G._farmOnIsland = dist <= FARM_ON_ISLAND_RADIUS
            if not _G._farmOnIsland then
                local entrance = (questName and ENTRANCE_TABLE[questName])
                              or (mobName   and MOB_ENTRANCE[mobName])
                if entrance and dist > ENTRANCE_DIST and CommF then
                    task.spawn(function()
                        pcall(function() CommF:InvokeServer("requestEntrance", entrance) end)
                    end)
                    task.wait(0.6)
                end
                local gate = findNearestFarmGate(targetCF.Position, hrp.Position)
                if gate and CommF then
                    task.spawn(function()
                        pcall(function()
                            CommF:InvokeServer("requestEntrance", gate)
                            hrp.CFrame = hrp.CFrame + Vector3.new(0, 50, 0)
                        end)
                    end)
                    task.wait(0.5)
                end
            else
                local entrance = (questName and ENTRANCE_TABLE[questName])
                              or (mobName   and MOB_ENTRANCE[mobName])
                if entrance and dist > ENTRANCE_DIST and CommF then
                    task.spawn(function()
                        pcall(function() CommF:InvokeServer("requestEntrance", entrance) end)
                    end)
                    task.wait(0.6)
                end
            end
            TweenPlayer(targetCF)
        end)
    end

    local function waitForRespawn()
        local t = tick()
        repeat task.wait(0.5) until tick() - t > 10
            or (Player.Character
                and Player.Character:FindFirstChildOfClass("Humanoid")
                and Player.Character:FindFirstChildOfClass("Humanoid").Health > 0)
    end

    local function StopTween(state)
        if not state then
            pcall(function()
                _G._farmOnIsland = false
                if _activeTween and _activeTween.PlaybackState == Enum.PlaybackState.Playing then
                    _activeTween:Cancel()
                end
                _activeTween   = nil
                _lastTweenDest = nil
                stopPartTele()
                PosMon  = nil
                MonFarm = nil
                local char = Player.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local bp = hrp:FindFirstChild("BodyClip")
                    if bp then bp:Destroy() end
                end
                if char and char:FindFirstChild("Root") then
                    char.Root:Destroy()
                end
                if char then
                    for _, partName in ipairs(NOCLIP_PARTS) do
                        local part = char:FindFirstChild(partName)
                        if part and part:IsA("BasePart") then
                            part.CanCollide = true
                        end
                    end
                end
            end)
        end
    end

    -- ✅ FIX #3: fightMob gọi NavigateTo với đầy đủ tham số mobName
    local function fightMob(mob, isEnabledFn)
        local char0 = Player.Character
        local hrp0  = char0 and char0:FindFirstChild("HumanoidRootPart")
        local hum0  = char0 and char0:FindFirstChildOfClass("Humanoid")
        if not hrp0 or not hum0 or hum0.Health <= 0 then return end
        if not mob or not mob.Parent then return end
        if not isAlive(mob) then return end
        local initHRP = mob:FindFirstChild("HumanoidRootPart")
        local initHum = mob:FindFirstChild("Humanoid")
        if not initHRP or not initHum then return end

        stabilizeMob(mob)

        -- Humanoid.Died = server xác nhận chết → thoát loop ngay, không chờ HP client
        local mobDied = false
        local diedConn; pcall(function()
            diedConn = initHum.Died:Connect(function() mobDied = true end)
        end)

        local lastSeenHealth = initHum.Health
        local lastHealthTick = tick()
        local attackCount    = 0
        local startTime      = tick()
        local HARD_TIMEOUT   = 45   -- boss có nhiều HP cần thêm thời gian
        local DESYNC_MIN_ATK = 10   -- phải đánh ít nhất N lần trước khi check desync
        local DESYNC_WINDOW  = 8    -- giây không giảm HP → desync

        local targetCF = CFrame.new(initHRP.Position) * Pos
        NavigateTo(targetCF, nil, mob.Name)
        pcall(function() VIM_SVC:CaptureController() end)

        repeat
            RunService.Heartbeat:Wait()

            if mobDied then break end
            if tick() - startTime > HARD_TIMEOUT then break end
            if not mob or not mob.Parent then break end

            local mobHum = mob:FindFirstChild("Humanoid")
            local mobHRP = mob:FindFirstChild("HumanoidRootPart")
            if not mobHum or not mobHRP then break end

            local curHealth = mobHum.Health
            if curHealth <= 0 then break end

            local charNow = Player.Character
            local hrpNow  = charNow and charNow:FindFirstChild("HumanoidRootPart")
            local humNow  = charNow and charNow:FindFirstChildOfClass("Humanoid")
            if not hrpNow or not humNow then break end
            if humNow.Health <= 0 then waitForRespawn(); break end

            -- HP tăng vọt = mob vừa respawn cùng instance → reset tracking
            -- Không gọi stabilizeMob lại ở đây — _stabConn đã tự handle qua Died event
            if curHealth > lastSeenHealth + 10 then
                lastSeenHealth = curHealth
                lastHealthTick = tick()
                attackCount    = 0
            elseif curHealth < lastSeenHealth - 0.5 then
                lastSeenHealth = curHealth
                lastHealthTick = tick()
            end

            -- Desync: chỉ bỏ qua nếu đã đánh đủ nhiều lần mà HP không giảm
            if attackCount >= DESYNC_MIN_ATK and tick() - lastHealthTick > DESYNC_WINDOW then
                _G.IgnoreMobs[mob] = tick()
                break
            end

            EquipWeapon(_G.SelectedWeaponName)
            AutoHaki()
            if mobHum.WalkSpeed ~= 0 then mobHum.WalkSpeed = 0 end
            if mobHum.JumpPower ~= 0 then mobHum.JumpPower = 0 end
            mobHRP.CanCollide = false
            local mobHead = mob:FindFirstChild("Head")
            if mobHead then mobHead.CanCollide = false end
            PosMon  = mobHRP.CFrame
            MonFarm = mob.Name
            pcall(function() hrpNow.CFrame = mobHRP.CFrame * Pos end)
            pcall(function()
                VIM_SVC:Button1Down(Vector2.new(1280, 672), workspace.CurrentCamera.CFrame)
            end)
            attackCount = attackCount + 1
        until not isEnabledFn() or mobDied
            or not mob.Parent
            or (function() local h = mob:FindFirstChild("Humanoid"); return h and h.Health <= 0 end)()

        pcall(function() diedConn:Disconnect() end)
    end

