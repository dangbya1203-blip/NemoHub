    local function findNearestMob(maxDist)
        local enemies = workspace:FindFirstChild("Enemies")
        if not enemies then return nil end
        local myHRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return nil end
        local closestMob, closestDist = nil, maxDist or 5000
        for _, v in pairs(enemies:GetChildren()) do
            local vHRP = v:FindFirstChild("HumanoidRootPart")
            if isAlive(v) and vHRP then
                local d = (myHRP.Position - vHRP.Position).Magnitude
                if d < closestDist then closestDist = d; closestMob = v end
            end
        end
        return closestMob
    end

    local function nearestFallback(isEnabledFn)
        local mob = findNearestMob(5000)
        if mob then fightMob(mob, isEnabledFn) end
    end

    local function navigateToSpawn(mobName, questName)
        local spawnCF = mobName and GetMobSpawnCFrame(mobName)
        if spawnCF then
            NavigateTo(CFrame.new(spawnCF.Position) * Pos, questName, mobName)
        elseif CFrameMon then
            NavigateTo(CFrameMon, questName, mobName)
        elseif CFrameQuest then
            NavigateTo(CFrameQuest, questName)
        end
    end

    local function findMobAndAct(mobName, actFn, questName)
        if not mobName then return false end
        local enemies = workspace:FindFirstChild("Enemies")
        if not enemies then navigateToSpawn(mobName, questName); return false end
        if not enemies:FindFirstChild(mobName) then
            navigateToSpawn(mobName, questName)
            return false
        end
        for _, v in pairs(enemies:GetChildren()) do
            if v.Name == mobName and isAlive(v) then
                actFn(v)
                return true
            end
        end
        navigateToSpawn(mobName, questName)
        return false
    end

    -- ✅ FIX #5: startQuestWithTimeout dùng vòng chờ thực để tránh race condition
    local function startQuestWithTimeout()
        if not CommF or not NameQuest or not CFrameQuest then return false end
        NavigateTo(CFrameQuest, NameQuest)
        local myHRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return false end
        if (CFrameQuest.Position - myHRP.Position).Magnitude > 20 then return false end

        pcall(function() CommF:InvokeServer("StartQuest", NameQuest, LevelQuest) end)

        -- Chờ tối đa 2s để server phản hồi (thay vì đọc ngay lập tức)
        local elapsed = 0
        repeat
            task.wait(0.1)
            elapsed = elapsed + 0.1
            local _, visibleNow = getQuestGui()
            if visibleNow then return true end
        until elapsed >= 2

        local _, visibleFinal = getQuestGui()
        return visibleFinal == true
    end

