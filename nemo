local function NavigateToSafeZone(itemName)
    local data = STOP_ITEMS[itemName]
    if not data then return end
    StatusLabel.Text = "Ban tim duoc: " .. itemName .. " - Di chuyen vung an toan..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    warn("[NemoHub] Ban tim duoc: " .. itemName)
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then TweenPlayer(data.pos); return end
    if (hrp.Position - data.pos.Position).Magnitude <= 200 then
        StatusLabel.Text = "Ban tim duoc: " .. itemName
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        return
    end
    local gates = SEA_GATES[data.seaKey] or {}
    local nearGate, nearDist = nil, math.huge
    for _, gv3 in ipairs(gates) do
        local d = (hrp.Position - gv3).Magnitude
        if d < nearDist then nearDist = d; nearGate = gv3 end
    end
    local gateOk = false
    if nearGate and nearDist < 2000 then
        local before = hrp.Position
        pcall(function() RS.Remotes.CommF_:InvokeServer("requestEntrance", nearGate) end)
        task.wait(2)
        char = LocalPlayer.Character; hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - before).Magnitude > 50 then gateOk = true end
    end
    if not gateOk then TweenPlayer(data.pos) end
    StatusLabel.Text = "Ban tim duoc: " .. itemName
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
end

