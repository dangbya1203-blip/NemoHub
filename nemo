-- SECTION 12 : FPS BOOSTER MODULE  (học từ BoneHub — 5 lớp tối ưu)
--==============================================================================
local FPSModule = {}

function FPSModule.Boost()
    local L = Services.Lighting
    local T = WS.Terrain

    -- Layer 1: Rendering backend → Compatibility (thấp nhất)
    pcall(function() sethiddenproperty(L, "Technology", 2) end)
    pcall(function() sethiddenproperty(T, "Decoration", false) end)

    -- Layer 2: Terrain water
    T.WaterWaveSize    = 0
    T.WaterWaveSpeed   = 0
    T.WaterReflectance = 0
    T.WaterTransparency= 1

    -- Layer 3: Lighting globals
    L.GlobalShadows         = false
    L.FogEnd                = 9e9
    L.FogStart              = 0
    L.Brightness            = 1.5
    L.Ambient               = Color3.new(1,1,1)
    L.OutdoorAmbient        = Color3.new(1,1,1)
    L.ClockTime             = 12
    L.GeographicLatitude    = 0
    L.ExposureCompensation  = 0.5

    -- Layer 4: Chất lượng render
    settings().Rendering.QualityLevel = "Level01"

    -- Layer 5: Dọn sạch PostFX + Particles + Lights + Sounds trong workspace
    local function removeEffect(obj)
        if not obj or not obj.Parent then return end
        local cls = obj.ClassName
        if cls == "Decal" or cls == "Texture" then
            obj:Destroy()
        elseif cls == "Part" or cls == "Union" or cls == "MeshPart" then
            obj.Material    = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            if cls == "MeshPart" then obj.TextureID = "" end
        elseif cls == "ParticleEmitter" or cls == "Trail"
            or cls == "Fire"          or cls == "Smoke"
            or cls == "Sparkles" then
            obj.Enabled = false
            obj:Destroy()
        elseif cls == "SpotLight" or cls == "PointLight"
            or cls == "SurfaceLight" then
            obj.Enabled = false
            obj:Destroy()
        elseif cls == "Beam" then
            obj.Enabled = false
            obj:Destroy()
        elseif cls == "Sound" then
            obj:Stop()
            obj:Destroy()
        end
    end

    -- Xóa Atmosphere
    local atm = L:FindFirstChild("Atmosphere")
    if atm then atm:Destroy() end

    -- Xóa PostEffect trong Lighting
    for _, e in ipairs(L:GetChildren()) do
        if e:IsA("PostEffect") then
            e.Enabled = false
            e:Destroy()
        end
    end

    -- Scan toàn bộ Workspace
    for _, v in ipairs(WS:GetDescendants()) do
        removeEffect(v)
    end

    -- Layer 6: GC × 2 (mark + sweep)
    task.wait(0.5)
    collectgarbage()
    collectgarbage()

    return true
end

