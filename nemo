--==============================================================================
-- SECTION 7 : ANCHOR-BLOCK TELEPORT MODULE  (học từ BoneHub _tp)
--   Thay vì tween HumanoidRootPart trực tiếp (dễ bị server reset),
--   ta tween một invisible "anchor" Part, rồi character bám theo.
--   Lợi ích: movement qua physics proxy → ít bị anti-cheat detect hơn.
--==============================================================================
local TpModule = {}

-- Tạo anchor block 1 lần duy nhất
local _anchor = Instance.new("Part")
_anchor.Name        = "NemoAnchor"
_anchor.Size        = Vector3.new(1,1,1)
_anchor.Anchored    = true
_anchor.CanCollide  = false
_anchor.CanTouch    = false
_anchor.Transparency= 1
_anchor.Parent      = WS

TpModule._active   = false  -- true khi đang farm
TpModule._tween    = nil

-- Tween anchor đến đích, character follow qua loop bên dưới
function TpModule.Go(targetCF, speed)
    if not targetCF then return end
    speed = speed or CFG.BringSpeed
    local dist = (targetCF.Position - _anchor.Position).Magnitude
    if dist < 1 then return end

    if TpModule._tween then TpModule._tween:Cancel() end

    local info  = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
    local tween = TW:Create(_anchor, info, { CFrame = targetCF })
    TpModule._tween = tween
    tween:Play()

    -- Tự hủy khi farm bị tắt giữa chừng
    task.spawn(function()
        while tween.PlaybackState == Enum.PlaybackState.Playing do
            if not TpModule._active then tween:Cancel() break end
            task.wait(0.05)
        end
    end)
end

-- Teleport tức thời (không tween) — dùng cho trường hợp đặc biệt
function TpModule.Warp(targetCF)
    local hrp = getHRP()
    if hrp then hrp.CFrame = targetCF end
    _anchor.CFrame = targetCF
end

function TpModule.SetActive(state)
    TpModule._active = state
    -- Khi tắt: restore CanCollide của character
    local char = getChar()
    if char then
        for _, part in ipairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = not state and true or false
            end
        end
    end
end

-- Loop: character bám anchor khi đang farm
task.spawn(function()
    while task.wait() do
        pcall(function()
            if TpModule._active then
                local hrp = getHRP()
                if hrp then
                    if (hrp.Position - _anchor.Position).Magnitude > 200 then
                        _anchor.CFrame = hrp.CFrame  -- reset nếu quá xa
                    else
                        hrp.CFrame = _anchor.CFrame  -- character follow anchor
                    end
                end
            end
        end)
    end
end)

--==============================================================================
-- SECTION 8 : MOB MODULE  (Centroid Bring + Animator:Destroy — học từ BoneHub)
--==============================================================================
local MobModule = {}

-- Tính vị trí trung bình (centroid) của tất cả mob cùng tên
local function getMobCentroid(mobName)
    local sum   = Vector3.zero
    local count = 0
    for _, v in ipairs(WS.Enemies:GetChildren()) do
        if v.Name == mobName and v:FindFirstChild("HumanoidRootPart") then
            sum   = sum + v.HumanoidRootPart.Position
            count = count + 1
        end
    end
    return count > 0 and (sum / count) or nil
end

-- Lấy danh sách mob còn sống
function MobModule.GetAlive(filterName)
    local result = {}
    local container = WS:FindFirstChild("Enemies")
    if not container then return result end
    for _, v in ipairs(container:GetChildren()) do
        local hum = v:FindFirstChild("Humanoid")
        if hum and hum.Health > 0 then
            if (not filterName) or v.Name == filterName then
                table.insert(result, v)
            end
        end
    end
    return result
end

-- Gom quái về centroid + lock + xóa Animator
function MobModule.BringAll(filterName)
    local hrp = getHRP()
    if not hrp then return end

    -- Tính centroid cho từng loại mob
    local centroids = {}
    local enemies   = WS:FindFirstChild("Enemies")
    if not enemies then return end

    for _, v in ipairs(enemies:GetChildren()) do
        if (not filterName) or v.Name == filterName then
            if not centroids[v.Name] then
                local c = getMobCentroid(v.Name)
                if c then centroids[v.Name] = c end
            end
        end
    end

    -- Tween từng mob về centroid của loại nó
    for _, v in ipairs(enemies:GetChildren()) do
        local hum    = v:FindFirstChild("Humanoid")
        local mobHRP = v:FindFirstChild("HumanoidRootPart")
        if hum and mobHRP and hum.Health > 0 then
            if (not filterName) or v.Name == filterName then
                local dist = (mobHRP.Position - hrp.Position).Magnitude
                if dist <= CFG.BringRadius then
                    local centroid = centroids[v.Name]
                    if centroid then
                        local targetCF = CFrame.new(centroid.X, centroid.Y, centroid.Z)
                        local mobDist  = (mobHRP.Position - centroid).Magnitude
                        if mobDist > 3 and mobDist <= 280 then
                            -- Tween về centroid
                            local info  = TweenInfo.new(mobDist / CFG.BringSpeed, Enum.EasingStyle.Linear)
                            TW:Create(mobHRP, info, { CFrame = targetCF }):Play()
                            -- Lock vận động
                            mobHRP.CanCollide = false
                            hum.WalkSpeed     = 0
                            hum.JumpPower     = 0
                            -- Xóa Animator → mob đứng im hoàn toàn (BoneHub trick)
                            local anim = hum:FindFirstChild("Animator")
                            if anim then anim:Destroy() end
                            -- Tăng simulation radius
                            pcall(function()
                                sethiddenproperty(Plr, "SimulationRadius", math.huge)
                            end)
                        end
                    end
                end
            end
        end
    end
end

-- Cache vị trí mob bằng Attribute (học từ BoneHub Attack.Kill)
function MobModule.LockPosition(mob)
    if not mob:GetAttribute("NemoLocked") then
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            mob:SetAttribute("NemoLocked", hrp.CFrame)
        end
    end
    return mob:GetAttribute("NemoLocked")
end

