local QuestModule = {}

function QuestModule.GetCurrentData()
    local ok, level = pcall(function() return Plr.Data.Level.Value end)
    if not ok then return nil end
    for _, entry in ipairs(QUEST_DB) do
        if level >= entry.minLv and level <= entry.maxLv then
            return entry
        end
    end
    return nil
end

function QuestModule.HasActiveQuest()
    local g = Plr:FindFirstChild("PlayerGui")
