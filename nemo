local Fluent, SaveManager, InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/discoart/FluentPlus/refs/heads/main/Beta.lua"))()

local Window = Fluent:CreateWindow({
    Title = "Nemo Hub",
    SubTitle = "Blox Fruits",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true, 
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" })
}

--========================================================================
-- 4. KẾT NỐI VÀO GIAO DIỆN (UI CONTROLS)
--========================================================================
-- Đồng bộ Dropdown với team người dùng đã chọn ở getgenv()
local TeamDropdown = Tabs.Main:AddDropdown("TeamSelect", {
    Title = "Select Team",
    Values = {"Marines", "Pirates"},
    Multi = false,
    Default = (selectedTeam == "Pirates") and 2 or 1, 
})

Tabs.Main:AddButton({
    Title = "Join Selected Team",
    Callback = function()
        local team = TeamDropdown.Value
        if not Plr.Team or Plr.Team.Name ~= team then
            pcall(function() 
                ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_"):InvokeServer("SetTeam", team) 
            end)
            Fluent:Notify({ Title = "Nemo Hub", Content = "Đã đổi sang team " .. team, Duration = 3 })
        else
            Fluent:Notify({ Title = "Nemo Hub", Content = "Bạn đã ở team " .. team .. " rồi!", Duration = 3 })
        end
    end
})

-- Công tắc Fast Attack
local AutoAttackEnabled = false
local FastAttackToggle = Tabs.Main:AddToggle("FastAttack", {
    Title = "Enable Fast Attack",
    Default = false
})

FastAttackToggle:OnChanged(function(Value)
    AutoAttackEnabled = Value
end)

-- Vòng lặp chạy ngầm Fast Attack
RunService.Heartbeat:Connect(function()
    if AutoAttackEnabled then
        FastAttackModule.ExecuteFastAttack()
    end
end)

