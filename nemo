-- stabilizeMob: tắt physics + animation → tiết kiệm FPS khi đánh boss
local _stabilized = setmetatable({}, {__mode = "k"})
local function stabilizeMob(mob)
    if _stabilized[mob] then return end
    _stabilized[mob] = true
    pcall(function()
        local hum = mob:FindFirstChildOfClass("Humanoid")
        local anim = mob:FindFirstChildOfClass("Animator") or mob:FindFirstChild("Animate")
        if anim then anim:Destroy() end
        if hum then
            hum.WalkSpeed = 0
            hum.JumpPower = 0
        end
        for _, part in pairs(mob:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
                part.Massless   = true
                pcall(function() part:SetNetworkOwner(nil) end)
            end
        end
    end)
end

-- antiKnockback: reset velocity quái sau Lerp
local function antiKnockback(hrp)
    pcall(function()
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end)
end

-- Pool cố định tránh tạo table mới mỗi 0.05s → không GC pressure
local _targets  = {}
local _pool     = {}
local _poolSize = 300
for i = 1, _poolSize do _pool[i] = {nil, nil} end

local function executeFastAttack()
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool or (tool.ToolTip ~= "Melee" and tool.ToolTip ~= "Sword") then return end
    if not RegisterAttack or not RegisterHit then return end

    local count     = 0
    local firstHead = nil
    for _, folder in ipairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
        if folder then
            for _, mob in ipairs(folder:GetChildren()) do
                if mob ~= char then
                    local hrp  = mob:FindFirstChild("HumanoidRootPart")
                    local head = mob:FindFirstChild("Head")
                    if hrp and head and isAlive(mob) and (hrp.Position - root.Position).Magnitude <= 65 then
                        if not firstHead then firstHead = head end
                        for _, part in ipairs(mob:GetChildren()) do
                            if part:IsA("BasePart") then
                                count = count + 1
                                local entry = _pool[count] or {nil, nil}
                                _pool[count] = entry
                                entry[1] = mob
                                entry[2] = part
                            end
                        end
                    end
                end
            end
        end
    end
    if count == 0 or not firstHead then return end

    table.clear(_targets)
    for i = 1, count do _targets[i] = _pool[i] end

    pcall(function()
        RegisterAttack:FireServer(0.0000000000001)
        RegisterHit:FireServer(firstHead, _targets)
        if hitRemote and hitRemoteId and CachedSeed ~= 0 then
            local enc = string.gsub("RE/RegisterHit", ".", function(c)
                return string.char(bit32.bxor(string.byte(c), math.floor(workspace:GetServerTimeNow()/10%10)+1))
            end)
            cloneref(hitRemote):FireServer(enc, bit32.bxor(hitRemoteId+909090, CachedSeed*2), firstHead, _targets)
        end
    end)
end

