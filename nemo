-- Fallback: nhảy + dịch chuyển vật lý vào rương khi firetouchinterest thất bại
local function jumpIntoChest(RootPart, Chest, maxAttempts)
    maxAttempts = maxAttempts or 4

    for attempt = 1, maxAttempts do
        if not Chest or not Chest.Parent then return end
        -- Refresh char/hum/RootPart mỗi attempt phòng respawn giữa chừng
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or hum.Health <= 0 or not root then return end

        local angle        = (attempt - 1) * (math.pi * 2 / maxAttempts) + math.random() * 0.3
        local approachDist = hrand(1.5, 2.5)
        root.CFrame        = Chest.CFrame * CFrame.new(math.cos(angle) * approachDist, 1.5, math.sin(angle) * approachDist)
        RunService.Heartbeat:Wait()

        hum.Jump = true
        pcall(function()
            root.AssemblyLinearVelocity = (Chest.Position - root.Position).Unit * 28
        end)
        task.wait(0.06)
        root.CFrame = Chest.CFrame * CFrame.new(0, 0.3, 0)

        pcall(function()
            if firetouchinterest then
                firetouchinterest(root, Chest, 0)
                task.wait(hrand(0.06, 0.10))
                firetouchinterest(root, Chest, 1)
            end
        end)
        if not Chest or not Chest.Parent then return end
    end
end

-- Touch chest: fire xong sang rương tiếp theo ngay, không chờ rương biến mất
local function TouchChest(RootPart, Chest)
    RootPart.CFrame = jitterCF(Chest.CFrame * CFrame.new(0, 0.5, 0))

    local fired = false
    pcall(function()
        if firetouchinterest then
            firetouchinterest(RootPart, Chest, 0)
            task.wait(hrand(0.07, 0.11))
            firetouchinterest(RootPart, Chest, 1)
            fired = true
        end
    end)

    -- Nếu không có firetouchinterest thì dùng jump fallback
    if not fired then
        jumpIntoChest(RootPart, Chest)
    end
end

local function GrabFruit(RootPart, fruit)
    local handle = fruit:FindFirstChild("Handle")
    if not handle then return end
    local targetCF = jitterCF(handle.CFrame, 0.3)
    Teleport(targetCF)  -- InstantTP tự set CFrame, non-instant tự di chuyển
    -- Refresh RootPart sau Teleport phòng respawn giữa chừng (non-instant mode)
    local freshChar = LocalPlayer.Character
    local freshRoot = freshChar and freshChar:FindFirstChild("HumanoidRootPart")
    if not freshRoot then return end
    pcall(function()
        if firetouchinterest then
            firetouchinterest(freshRoot, handle, 0)
            task.wait(hrand(0.08, 0.15))
            firetouchinterest(freshRoot, handle, 1)
        end
    end)
    task.wait(hrand(0.4, 0.7))
    StoreFruit()
end

-- Kiểm tra ngắt giữa chest loop
local function ShouldBreakChest()
    if CollectFruit and #GetDroppedFruits() > 0 then return true end
    if AutoDoughKing and PlaceId == SEA3_PLACE then
        -- Break nếu có chalice để craft, hoặc Dough King đã spawn (cần đánh ngay)
        if GetBP("God's Chalice") or GetBP("Sweet Chalice")
            or GetConnectionEnemies("Dough King") then return true end
    end
    if AutoDarkbeard and PlaceId == SEA2_PLACE then
        if HasFistOfDarkness() or GetDarkbeard() then return true end
    end
    return false
end

local function main()
    AutoSelectTeam()

    while true do
        local char = LocalPlayer.Character
        local RootPart = char and char:FindFirstChild("HumanoidRootPart")
        if not RootPart then task.wait(1); continue end

        -- [ƯU TIÊN 1] Lụm Trái
        if CollectFruit then
            local fruits = GetDroppedFruits()
            if #fruits > 0 then
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Phát hiện Trái! Đang lụm..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                GrabFruit(RootPart, fruits[1])
                task.wait(0.3)
                continue
            end
        end

        -- [ƯU TIÊN 2] Dough King (Sea 3)
        if AutoDoughKing and PlaceId == SEA3_PLACE then
            local hasChalice = GetBP("God's Chalice") or GetBP("Sweet Chalice")
            -- Vào chain nếu: có chalice (cần craft/spawn), HOẶC Dough King đã spawn
            -- (Sweet Chalice bị consume sau CakePrinceSpawner → hasChalice = false
            --  nhưng boss đã ở đó, phải tiếp tục đánh chứ không farm chest)
            local doughKingActive = GetConnectionEnemies("Dough King") ~= nil
            if hasChalice or doughKingActive then
                RunDoughKingChain()
                task.wait(0.05)
                continue
            end
        end

        -- [ƯU TIÊN 3] Darkbeard (Sea 2)
        if AutoDarkbeard and PlaceId == SEA2_PLACE then
            local darkbeard = GetDarkbeard()
            if darkbeard then
                -- Boss đã spawn → đánh
                _G.IsAttackingBoss = true
                StatusLabel.Text = "Status: Đánh Darkbeard!!!"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                PositionOnBoss(darkbeard)
                task.wait(0.05)
                continue
            elseif HasFistOfDarkness() then
                -- Có Fist nhưng boss chưa spawn → kích hoạt tại Dark Arena
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Đang dùng Fist of Darkness tại Dark Arena..."
                StatusLabel.TextColor3 = Color3.fromRGB(150, 50, 255)
                ActivateFistAtAltar()
                -- Sau khi activate, chờ boss spawn tối đa 8s rồi recheck
                local deadline = tick() + 8
                while tick() < deadline do
                    task.wait(0.5)
                    if GetDarkbeard() then break end
                    -- Nếu vì lý do gì Fist biến mất (die/disconnect), thoát vòng chờ
                    if not HasFistOfDarkness() then break end
                end
                continue
            end
        end

        -- [ƯU TIÊN 4] Auto Chest
        -- Guard: nếu ShouldBreakChest đúng ngay tại đây (Fist/Chalice/Darkbeard vừa xuất hiện
        -- trong lúc đang xử lý priority 1-3 ở trên) thì continue lại từ đầu để priority 3 xử lý.
        if ShouldBreakChest() then task.wait(); continue end

        _G.IsAttackingBoss = false
        StatusLabel.Text = "Status: Auto Chest (Instant)"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)

        local Chests = getChestsSorted()
        if #Chests == 0 then
            StatusLabel.Text = "Status: Không có rương, chờ 3s rồi hop..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            local antiKickEnd = tick() + 3
            while tick() < antiKickEnd do
                -- Trong lúc chờ anti-kick, check Fist mỗi 0.8s.
                -- Nếu có Fist thì KHÔNG hop — break ra ngoài để main loop xử lý.
                if ShouldBreakChest() then break end
                pcall(function()
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton2(Vector2.new(
                        math.random(200, 600), math.random(200, 500)
                    ))
                end)
                task.wait(0.8)
            end
            -- Kiểm tra lần cuối trước khi hop: nếu vừa nhặt được Fist/Chalice thì không hop
            if ShouldBreakChest() then task.wait(); continue end
            HopServer()
            task.wait(3)
            continue
        end

        for _, Chest in ipairs(Chests) do
            if ShouldBreakChest() then break end
            char = LocalPlayer.Character
            RootPart = char and char:FindFirstChild("HumanoidRootPart")
            if not RootPart then break end
            if Chest and Chest.Parent and Chest:FindFirstChild("TouchInterest") then
                TouchChest(RootPart, Chest)
                IgnoredChests[Chest] = tick()
                -- Yield 0.15s sau mỗi chest để server kịp trả Fist về Backpack
                task.wait(0.15)
                if ShouldBreakChest() then break end
            end
        end

        task.wait()
    end
end

main()
