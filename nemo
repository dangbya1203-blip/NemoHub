local function DistanceFromPlrSort(ObjectList)
    local RootPart = getCharacter():WaitForChild("HumanoidRootPart")
    table.sort(ObjectList, function(A, B) return (RootPart.Position - A.Position).Magnitude < (RootPart.Position - B.Position).Magnitude end)
end

local function getChestsSorted()
    if FirstRun then FirstRun = false; for _, Object in ipairs(workspace:GetDescendants()) do if Object:IsA("Part") and Object.Name:find("Chest") then table.insert(UncheckedChests, Object) end end; _chestsDirty = true end
    if _chestsDirty then
        _chestsDirty = false; local cleaned = {}
        for _, Chest in ipairs(UncheckedChests) do if Chest and Chest.Parent then table.insert(cleaned, Chest) end end
        UncheckedChests = cleaned
    end
    local now = tick(); local char = LocalPlayer.Character; local RootPart = char and char:FindFirstChild("HumanoidRootPart"); local Chests = {}
    for _, Chest in ipairs(UncheckedChests) do
        if Chest:IsA("BasePart") and Chest:FindFirstChild("TouchInterest") then
            local lastTouched = IgnoredChests[Chest]
            if not lastTouched or (now - lastTouched > CHEST_IGNORE_TIME) then table.insert(Chests, Chest) end
        end
    end
    if RootPart then
        local rx, ry, rz = RootPart.Position.X, RootPart.Position.Y, RootPart.Position.Z
        table.sort(Chests, function(A, B)
            local ax, ay, az = A.Position.X - rx, A.Position.Y - ry, A.Position.Z - rz
            local bx, by, bz = B.Position.X - rx, B.Position.Y - ry, B.Position.Z - rz
            return ax*ax + ay*ay + az*az < bx*bx + by*by + bz*bz
        end)
    end
    return Chests
end

local function HopServer()
    StatusLabel.Text = "Status: Đang tìm server ngon..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    local function fetchPage(cursor)
        local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100" .. (cursor ~= "" and ("&cursor=" .. cursor) or "")
        local ok, res = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
        if ok and res and res.data then return res.data, res.nextPageCursor end
        return nil, nil
    end
    local allServers = {}; local page1, cur2 = fetchPage("")
    if page1 then for _, s in ipairs(page1) do table.insert(allServers, s) end end
    if cur2 then local page2, _ = fetchPage(cur2); if page2 then for _, s in ipairs(page2) do table.insert(allServers, s) end end end
    local validServers = {}
    for _, Server in ipairs(allServers) do
        local playing = Server.playing or 0; local maxP = Server.maxPlayers or 0; local freeSlots = maxP - playing
        if playing > 0 and freeSlots >= 2 and not isServerCoolingDown(Server.id) then table.insert(validServers, Server) end
    end
    table.sort(validServers, function(a, b) return (a.playing or 0) > (b.playing or 0) end)
    if #validServers > 0 then
        local best = validServers[1]
        StatusLabel.Text = string.format("Status: Hop → server %d/%d người", best.playing, best.maxPlayers)
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        VisitedServers[game.JobId] = os.time()
        pcall(function() if writefile then writefile(ServerFile, HttpService:JSONEncode(VisitedServers)) end end); task.wait(0.1)
        TeleportService:TeleportToPlaceInstance(PlaceId, best.id, LocalPlayer)
        return
    end
    StatusLabel.Text = "Status: Dọn cache server cũ, hop lại..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 0)
    local now = os.time()
    for jobId, t in pairs(VisitedServers) do if (now - t) >= SERVER_COOLDOWN then VisitedServers[jobId] = nil end end
    pcall(function() if writefile then writefile(ServerFile, HttpService:JSONEncode(VisitedServers)) end end); task.wait(0.5)
    TeleportService:Teleport(PlaceId, LocalPlayer)
end

