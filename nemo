    return LocalPlayer.Backpack:FindFirstChild(name) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(name))
end

-- Stop script ngay khi có item quan trọng
local STOP_ITEMS = {
    "Fist of Darkness",   -- key râu đen
    "God's Chalice",      -- god chalice
}
local function CheckStopItems()
    for _, itemName in ipairs(STOP_ITEMS) do
        if GetBP(itemName) then
            return itemName
        end
    end
    return nil
end

task.spawn(function()
    while getgenv().NemoRunning do
        task.wait(0.5)
        local found = CheckStopItems()
        if found then
            getgenv().NemoRunning = false
            warn("[NemoHub] Bạn tìm được: " .. found)
            StatusLabel.Text = "Bạn tìm được: " .. found
            StatusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
            break
        end
    end
end)

local _invCache = { data = nil, time = 0 }
local function GetM(name)
    if not _invCache.data or (tick() - _invCache.time > 3) then
        local ok, result = pcall(function() return replicated.Remotes.CommF_:InvokeServer("getInventory") end)
        _invCache.data = (ok and result) or _invCache.data or {}
        _invCache.time = tick()
    end
    for _, tab in pairs(_invCache.data) do
        if type(tab) == "table" and tab.Type == "Material" and tab.Name == name then return tab.Count or 0 end
    end
    return 0
end

local function EquipWeapon(name)
    if not name then return end
    local tool = LocalPlayer.Backpack:FindFirstChild(name)
    if tool and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:EquipTool(tool)
    end
end

-- Tự động equip Melee nếu tay đang trống hoặc không cầm Melee/Sword
local function AutoEquipMelee()
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    -- Kiểm tra đang cầm gì
    local current = char:FindFirstChildOfClass("Tool")
    if current and (current.ToolTip == "Melee" or current.ToolTip == "Sword") then return end
    -- Tìm Melee trong Backpack
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.ToolTip == "Melee" then
            hum:EquipTool(tool)
            return
        end
    end
    -- Fallback: Sword nếu không có Melee
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.ToolTip == "Sword" then
            hum:EquipTool(tool)
            return
        end
    end
end

local function GetConnectionEnemies(a)
    for _, folder in ipairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
        if folder then
            for _, v in pairs(folder:GetChildren()) do
                if v:IsA("Model") and ((typeof(a) == "table" and table.find(a, v.Name)) or v.Name == a) and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then return v end
            end
        end
    end
end

local function StoreFruit()
    local function CheckAndStore(parent)
        for _, item in ipairs(parent:GetChildren()) do
            if item:FindFirstChild("EatRemote", true) or string.find(string.lower(item.Name), "fruit") then
                local fruitName = item:GetAttribute("OriginalName") or string.gsub(item.Name, " Fruit", "")
                pcall(function() replicated.Remotes.CommF_:InvokeServer("StoreFruit", fruitName, item) end)
            end
        end
    end
    if LocalPlayer:FindFirstChild("Backpack") then CheckAndStore(LocalPlayer.Backpack) end
    if LocalPlayer.Character then CheckAndStore(LocalPlayer.Character) end
end




