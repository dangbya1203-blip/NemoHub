local function AutoSelectTeam()
    local function hasRealTeam()
        if LocalPlayer:FindFirstChild("Main") then return true end
        local t = LocalPlayer.Team
        return t ~= nil and t.Name ~= "Neutral" and t.Name ~= ""
    end
    if hasRealTeam() then return end

    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    local teamName  = JoinTeam  

    local function trySelectTeam()
        pcall(function()
            local mainMinimal = PlayerGui:FindFirstChild("Main (minimal)")
            local chooseTeam  = mainMinimal and mainMinimal:FindFirstChild("ChooseTeam")
            if chooseTeam and chooseTeam.Visible then RS.Remotes.CommF_:InvokeServer("SetTeam", teamName) end
        end)
        pcall(function() RS.Remotes.CommF_:InvokeServer("SelectTeam", teamName) end)
        pcall(function()
            local mainMinimal = PlayerGui:FindFirstChild("Main (minimal)")
            if not mainMinimal then return end
            local chooseTeam = mainMinimal:FindFirstChild("ChooseTeam", true)
            if not chooseTeam or not chooseTeam.Visible then return end
            local button
            for _, obj in ipairs(chooseTeam:GetDescendants()) do
                if (obj:IsA("TextButton") or obj:IsA("ImageButton"))
                    and (string.find(string.lower(obj.Name), string.lower(teamName))
                      or (obj.Parent and string.find(string.lower(obj.Parent.Name), string.lower(teamName))))
                then button = obj; break end
            end
            if button then
                if getconnections then
                    for _, conn in ipairs(getconnections(button.Activated)) do pcall(conn.Function) end
                else
                    local vim = game:GetService("VirtualInputManager")
                    local pos = button.AbsolutePosition + button.AbsoluteSize / 2
                    vim:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 1)
                    task.wait(0.05)
                    vim:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 1)
                end
            end
        end)
    end

    local lastAttempt = 0
    while not hasRealTeam() and getgenv().NemoRunning do
        if tick() - lastAttempt >= 0.5 then
            trySelectTeam()
            lastAttempt = tick()
        end
        task.wait()
    end
end

local function getCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    char:WaitForChild("HumanoidRootPart")
    return char
end

local function toggleNoclip(Toggle)
    local Char = getCharacter()
    for _, v in ipairs(Char:GetChildren()) do if v:IsA("Part") then v.CanCollide = not Toggle end end
    local Humanoid = Char:FindFirstChild("Humanoid")
    if Humanoid then Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, not Toggle) end
end

local function Teleport(Goal, Speed)
    local RootPart = getCharacter().HumanoidRootPart
    if InstantTP then RootPart.CFrame = Goal
    else
        Speed = Speed or MaxSpeed
        toggleNoclip(true)
        pcall(function()
            local Magnitude = (RootPart.Position - Goal.Position).Magnitude
            while Magnitude > 1 and getgenv().NemoRunning do
                if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
                local Direction    = (Goal.Position - RootPart.Position).unit
                local NextPosition = RootPart.Position + Direction * math.min(Speed * task.wait(), Magnitude)
                if (NextPosition - Goal.Position).Magnitude < 1 then RootPart.CFrame = Goal; break end
                RootPart.CFrame = CFrame.new(NextPosition)
                Magnitude = (RootPart.Position - Goal.Position).Magnitude
            end
        end)
        toggleNoclip(false) 
    end
end

-- Tween TP an toàn cho boss/altar — KHÔNG dùng InstantTP dù config = true
-- Di chuyển từng bước nhỏ ~120 studs/s, server không detect giật cục
-- TweenPlayer: TweenService trực tiếp lên HRP (bancu pattern)
-- Server thấy velocity liên tục smooth → không bị detect/kick
-- BodyVelocity "BodyClip" chống gravity kéo xuống khi tween ngang
local TweenService  = game:GetService("TweenService")
local TWEEN_SPEED   = 300  -- studs/s
local _activeTween  = nil

local function _ensureBodyVelocity(hrp)
    if not hrp:FindFirstChild("BodyClip") then
        local bv    = Instance.new("BodyVelocity")
        bv.Name     = "BodyClip"
        bv.Parent   = hrp
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
        bv.Velocity = Vector3.new(0, 0, 0)
    end
end

local function _removeBodyVelocity(hrp)
    local bp = hrp and hrp:FindFirstChild("BodyClip")
    if bp then bp:Destroy() end
end

local function TweenPlayer(goalCF)
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist = (hrp.Position - goalCF.Position).Magnitude
    if dist < 1 then return end
    if _activeTween and _activeTween.PlaybackState == Enum.PlaybackState.Playing then
        _activeTween:Cancel()
    end
    toggleNoclip(true)
    _ensureBodyVelocity(hrp)
    local info   = TweenInfo.new(dist / TWEEN_SPEED, Enum.EasingStyle.Linear)
    _activeTween = TweenService:Create(hrp, info, {CFrame = goalCF})
    _activeTween:Play()
    _activeTween.Completed:Wait()
    toggleNoclip(false)
    -- Destroy BodyVelocity ngay sau khi tween xong — không để lơ lửng
    _removeBodyVelocity(hrp)
end

-- SafeTweenTP alias → TweenPlayer (không đổi các chỗ gọi cũ)
local function SafeTweenTP(goalCF, _speed)
    TweenPlayer(goalCF)
end

