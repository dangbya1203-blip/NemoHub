    local _stabilized = setmetatable({}, {__mode = "k"})
    local _stabConn   = setmetatable({}, {__mode = "k"})
    local function stabilizeMob(mob)
        if _stabilized[mob] then return end
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        local hum = mob:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        _stabilized[mob] = true
        pcall(function()
            hum.AutoRotate    = false
            hum.JumpPower     = 0
            hum.WalkSpeed     = 0
            hum:ChangeState(14)
            for _, part in pairs(mob:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    part.Massless   = true
                end
            end
        end)
        -- Disconnect connection cũ nếu tồn tại, rồi tạo mới (tránh leak qua nhiều respawn)
        if _stabConn[mob] then
            pcall(function() _stabConn[mob]:Disconnect() end)
            _stabConn[mob] = nil
        end
        _stabConn[mob] = hum.Died:Connect(function()
            _stabilized[mob]   = nil
            _G.IgnoreMobs[mob] = nil
            -- Disconnect chính mình để không giữ reference
            if _stabConn[mob] then
                pcall(function() _stabConn[mob]:Disconnect() end)
                _stabConn[mob] = nil
            end
        end)
    end

    local function GetMobSpawnCFrame(mobName)
        local worldOrigin = workspace:FindFirstChild("_WorldOrigin")
        local enemySpawns = worldOrigin and worldOrigin:FindFirstChild("EnemySpawns")
        if enemySpawns then
            for _, spawner in pairs(enemySpawns:GetChildren()) do
                if spawner.Name == mobName then return spawner.CFrame end
            end
            for _, spawner in pairs(enemySpawns:GetChildren()) do
                if string.find(spawner.Name, mobName, 1, true) then return spawner.CFrame end
            end
        end
        local enemies = workspace:FindFirstChild("Enemies")
        if enemies then
            for _, v in pairs(enemies:GetChildren()) do
                if string.find(v.Name, mobName, 1, true) and isAlive(v) then
                    local hrp = v:FindFirstChild("HumanoidRootPart")
                    if hrp then return hrp.CFrame end
                end
            end
        end
        return nil
    end

    local TweenSpeed     = 500
