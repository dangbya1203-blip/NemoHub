    local _targets = {}
    local _pool    = {}
    local _poolSize = 300
    for i = 1, _poolSize do _pool[i] = {nil, nil} end

    local function executeFastAttack(toolTipFilter)
        local char = Player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not root then return end
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then return end
        local tip = tool.ToolTip
        if toolTipFilter then
            if tip ~= toolTipFilter then return end
        else
            if tip ~= "Melee" and tip ~= "Sword" then return end
        end
        -- ── LeftClickRemote path (Ten Hub pattern) ──────────────────
        if tool:FindFirstChild("LeftClickRemote") then
            local attackCount = 1
            local playerPos   = root.Position
            local enemies     = workspace:FindFirstChild("Enemies")
            if enemies then
                for _, enemy in ipairs(enemies:GetChildren()) do
                    local eHRP = enemy:FindFirstChild("HumanoidRootPart")
                    if eHRP and isAlive(enemy) and (eHRP.Position - playerPos).Magnitude <= 60 then
                        pcall(function()
                            local direction = (eHRP.Position - playerPos).Unit
                            tool.LeftClickRemote:FireServer(direction, attackCount)
                        end)
                        attackCount = attackCount + 1
                        if attackCount > 1e13 then attackCount = 1 end
                    end
                end
            end
            return
        end
        -- ── RegisterAttack / RegisterHit fallback ───────────────────
        if not RegisterAttack or not RegisterHit then return end
        local count = 0
        local firstHead = nil
        for _, folder in ipairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
            if folder then
                for _, mob in ipairs(folder:GetChildren()) do
                    if mob ~= char then
                        local hrp  = mob:FindFirstChild("HumanoidRootPart")
                        local head = mob:FindFirstChild("Head")
                        if hrp and head and isAlive(mob) and (hrp.Position - root.Position).Magnitude <= 100 then
                            if not firstHead then firstHead = head end
                            for _, part in ipairs(mob:GetChildren()) do
                                if part:IsA("BasePart") then
                                    count = count + 1
                                    local entry = _pool[count]
                                    if not entry then entry = {nil, nil}; _pool[count] = entry end
                                    entry[1] = mob; entry[2] = part
                                end
                            end
                        end
                    end
                end
            end
        end
        if count == 0 or not firstHead then return end
        table.clear(_targets)
        for i = 1, count do _targets[i] = _pool[i] end
        pcall(function()
            RegisterAttack:FireServer(0.0000000000001)
            RegisterHit:FireServer(firstHead, _targets)
            if hitRemote and hitRemoteId and CachedSeed ~= 0 then
                local enc = string.gsub("RE/RegisterHit", ".", function(c)
                    return string.char(bit32.bxor(string.byte(c), math.floor(workspace:GetServerTimeNow()/10%10)+1))
                end)
                cloneref(hitRemote):FireServer(enc, bit32.bxor(hitRemoteId+909090, CachedSeed*2), firstHead, _targets)
            end
        end)
    end

    local function Attack()
        if _G_FastAttack then pcall(executeFastAttack) end
    end
    local function AttackMastery(toolTip)
