local Inventory = {}

-- Lấy tool từ Backpack hoặc Character đang equip
function Inventory.GetBP(name)
    return Plr.Backpack:FindFirstChild(name)
        or (getChar() and getChar():FindFirstChild(name))
end

-- Kiểm tra item trong inventory server-side
function Inventory.Has(name)
    local ok, inv = pcall(function()
        return Remotes.CommF:InvokeServer("getInventory")
    end)
    if not ok or type(inv) ~= "table" then return false end
    for _, v in ipairs(inv) do
        if type(v) == "table" and v.Name == name then return true end
    end
    return false
end

-- Đếm số lượng material
function Inventory.GetMaterialCount(name)
    local ok, inv = pcall(function()
        return Remotes.CommF:InvokeServer("getInventory")
    end)
    if not ok or type(inv) ~= "table" then return 0 end
    for _, v in ipairs(inv) do
        if type(v) == "table" and v.Type == "Material" and v.Name == name then
            return v.Count or 0
        end
    end
    return 0
end

-- Kiểm tra có sword tên này không
function Inventory.HasSword(name)
    if Inventory.GetBP(name) then return true end
    local ok, inv = pcall(function()
        return Remotes.CommF:InvokeServer("getInventory")
    end)
    if not ok or type(inv) ~= "table" then return false end
    for _, v in ipairs(inv) do
        if type(v) == "table" and v.Type == "Sword" and v.Name == name then
            return true
        end
    end
    return false
end

