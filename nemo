-- Danh sách limb để random hit part
local LIMBS = {"RightLowerArm","RightUpperArm","LeftLowerArm","LeftUpperArm","RightHand","LeftHand"}

-- Gửi hit cho TẤT CẢ quái trong tầm 65 studs
local function executeFastAttack(toolTipFilter)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then return end
    local tool = char:FindFirstChildOfClass("Tool"); if not tool then return end
    local tip  = tool.ToolTip
    if toolTipFilter then
        if tip ~= toolTipFilter then return end
    else
        if tip ~= "Melee" and tip ~= "Sword" and tip ~= "Blox Fruit" and tip ~= "Gun" then return end
    end

    local rootPos = root.Position

    -- Blox Fruit dùng LeftClickRemote riêng
    if tip == "Blox Fruit" and tool:FindFirstChild("LeftClickRemote") then
        local lcr = tool.LeftClickRemote; local hasMob = false
        for _, folder in ipairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
            if folder then
                for _, enemy in ipairs(folder:GetChildren()) do
                    local eHRP = enemy:FindFirstChild("HumanoidRootPart")
                    if eHRP and isAlive(enemy) and not enemy:GetAttribute("IsBoat")
                        and (eHRP.Position - rootPos).Magnitude <= 65
                    then hasMob = true; break end
                end
            end
            if hasMob then break end
        end
        if hasMob then
            pcall(function()
                lcr:FireServer(Vector3.new(0.01, -500, 0.01), 1, true)
                lcr:FireServer(false)
            end)
        end
        return
    end

    -- Melee / Sword / Gun: build target list
    local mainTarget = nil; local targets = {}
    for _, folder in ipairs({workspace:FindFirstChild("Enemies"), workspace:FindFirstChild("Characters")}) do
        if folder then
            for _, mob in ipairs(folder:GetChildren()) do
                if mob ~= char and isAlive(mob) and not mob:GetAttribute("IsBoat") then
                    local hrp  = mob:FindFirstChild("HumanoidRootPart")
                    local head = mob:FindFirstChild("Head")
                    if hrp and head and (hrp.Position - rootPos).Magnitude <= 65 then
                        if not mainTarget then mainTarget = head end
                        local hitPart = mob:FindFirstChild(LIMBS[math.random(#LIMBS)]) or hrp
                        table.insert(targets, {mob, hitPart})
                    end
                end
            end
        end
    end
    if not mainTarget or #targets == 0 then return end

    -- Gửi hit theo thứ tự ưu tiên
    if CombatFlags and HitFunction then
        pcall(function() RegisterAttack:FireServer(0); HitFunction(mainTarget, targets) end)
        return
    end
    if RegisterAttack and RegisterHit then
        pcall(function() RegisterAttack:FireServer(0); RegisterHit:FireServer(mainTarget, targets) end)
        return
    end
    if HNCHit and HNCAtk then
        local id = tostring(Player.UserId):sub(2,4) .. tostring(coroutine.running()):sub(11,15)
        pcall(function() HNCAtk:FireServer() end)
        pcall(function() HNCHit:FireServer(mainTarget, targets, nil, nil, id) end)
    end
end

-- Hit registration fallback với XOR seed (anti-cheat bypass)
local function executeHitRegistration()
    pcall(function()
        local char = Player.Character; if not char then return end
        local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local hitTargets = {}
        local function scanEnemyFolder(folder)
            if not folder then return end
            for _, target in ipairs(folder:GetChildren()) do
                local hum2 = target:FindFirstChild("Humanoid"); local hrp2 = target:FindFirstChild("HumanoidRootPart")
                if hum2 and hrp2 and hum2.Health > 0 and target ~= char
                    and (hrp2.Position - hrp.Position).Magnitude <= 60
                then
                    for _, child in ipairs(target:GetChildren()) do
                        if child:IsA("BasePart") then table.insert(hitTargets, {target, child}) end
                    end
                end
            end
        end
        scanEnemyFolder(workspace:FindFirstChild("Enemies"))
        scanEnemyFolder(workspace:FindFirstChild("Characters"))
        if #hitTargets == 0 then return end

        local tool  = char:FindFirstChildOfClass("Tool"); if not tool then return end
        local wType = tool:GetAttribute("WeaponType")
        if wType ~= "Melee" and wType ~= "Sword" then return end

        local Modules = RS:FindFirstChild("Modules"); local Net2 = Modules and Modules:FindFirstChild("Net"); if not Net2 then return end
        local seed = 0; pcall(function() seed = Net2.seed:InvokeServer() end)
        local attackRemote2 = Net2:FindFirstChild("RE/RegisterAttack")
        local hitRemote2    = Net2:FindFirstChild("RE/RegisterHit")
        if not attackRemote2 or not hitRemote2 then return end
        pcall(function() attackRemote2:FireServer() end)
        local targetHead = hitTargets[1][1]:FindFirstChild("Head"); if not targetHead then return end
        pcall(function() hitRemote2:FireServer(targetHead, hitTargets, {}) end)

        -- XOR encode bypass
        if _hitRegData.remote and _hitRegData.remoteId then
            pcall(function()
                local remoteCode    = "RE/RegisterHit"
                local encKey        = math.floor(workspace:GetServerTimeNow() / 10 % 10) + 1
                local encodedString = string.gsub(remoteCode, ".", function(c)
                    return string.char(bit32.bxor(string.byte(c), encKey))
                end)
                local finalId = bit32.bxor(_hitRegData.remoteId + 909090, seed * 2)
                cloneref(_hitRegData.remote):FireServer(encodedString, finalId, targetHead, hitTargets)
            end)
        end
    end)
end

