    local function _masteryCombatLoop(v, isEnabledFn, masteryWeapon, primaryWeapon, healthThreshold, weaponTip)
        local initVHRP = v:FindFirstChild("HumanoidRootPart")
        if not initVHRP then return end
        local targetCF       = CFrame.new(initVHRP.Position) * Pos
        TweenPlayer(targetCF)
        local initVHum       = v:FindFirstChild("Humanoid")
        if not initVHum then return end

        local mobDied = false
        local diedConn; pcall(function()
            diedConn = initVHum.Died:Connect(function() mobDied = true end)
        end)

        local lastSeenHP     = initVHum.Health
        local lastHPTick     = tick()
        local atkCount       = 0
        local startCL        = tick()
        local lastAttackFire = 0
        local weaponEquipped = nil
        repeat
            RunService.Heartbeat:Wait()
            if mobDied then break end
            if tick() - startCL > 45 then break end
            local vHRP = v:FindFirstChild("HumanoidRootPart")
            local vHum = v:FindFirstChild("Humanoid")
            if not vHRP or not vHum then break end
            local currentHealthPct = vHum.MaxHealth > 0 and (vHum.Health / vHum.MaxHealth * 100) or 0
            if vHum.Health <= 0 then break end
            -- HP tăng = mob respawn → reset tracking
            if vHum.Health > lastSeenHP + 10 then
                lastSeenHP = vHum.Health; lastHPTick = tick(); atkCount = 0
            elseif vHum.Health < lastSeenHP - 0.5 then
                lastSeenHP = vHum.Health; lastHPTick = tick()
            end
            if atkCount >= 10 and tick() - lastHPTick > 8 then break end
            AutoHaki()
            if vHum.WalkSpeed ~= 0 then vHum.WalkSpeed = 0 end
            PosMon = vHRP.CFrame; MonFarm = v.Name
            targetCF = CFrame.new(vHRP.Position) * Pos
            local charNowM = Player.Character
            local hrpNowM  = charNowM and charNowM:FindFirstChild("HumanoidRootPart")
            if hrpNowM and (hrpNowM.Position - targetCF.Position).Magnitude > 10 then
                TweenPlayer(targetCF)
            end
            local neededWeapon = currentHealthPct > healthThreshold and primaryWeapon or masteryWeapon
            if neededWeapon ~= weaponEquipped then
                EquipWeapon(neededWeapon)
                weaponEquipped = neededWeapon
            end
            local now = tick()
            if now - lastAttackFire >= 0.05 then
                lastAttackFire = now
                if currentHealthPct <= healthThreshold then
                    AttackMastery(weaponTip)
                    atkCount = atkCount + 1
                    if _G.MasteryAutoSkill and currentHealthPct <= KillPercent then
                        pcall(function()
                            local tool2 = Player.Character:FindFirstChild(masteryWeapon)
                            if tool2 then
                                local mousePosVal = tool2:FindFirstChild("MousePos")
                                if mousePosVal then mousePosVal.Value = vHRP.Position end
                            end
                            -- Update namecall hook position targets
                            if weaponTip == "Blox Fruit" then
                                PositionSkillMasteryDevilFruit = vHRP.Position
                                _G.UseSkill = true
                            elseif weaponTip == "Gun" then
                                PositionSkillMasteryGun = vHRP.Position
                                _G.UseSkillGun = true
                            end
                            fireSkill(Enum.KeyCode.Z)
                            fireSkill(Enum.KeyCode.X)
                            fireSkill(Enum.KeyCode.C)
                            fireSkill(Enum.KeyCode.V)
                            task.wait(0.1)
                            _G.UseSkill    = false
                            _G.UseSkillGun = false
                        end)
                    end
                end
            end
        until not isEnabledFn() or mobDied
            or not v.Parent
            or (function() local h = v:FindFirstChild("Humanoid"); return h and h.Health <= 0 end)()
        pcall(function() diedConn:Disconnect() end)
    end

    local function runMasteryLoop(isEnabledFn, getWeaponFn, weaponTip)
