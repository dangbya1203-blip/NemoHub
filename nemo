-- SECTION 11: FPS BOOSTER  (BoneHub 6-layer)
--==============================================================================
local FPSModule = {}

function FPSModule.Boost()
    pcall(function()
        local L = Lighting
        local T = WS.Terrain
        pcall(function() sethiddenproperty(L,"Technology",2) end)
        pcall(function() sethiddenproperty(T,"Decoration",false) end)
        T.WaterWaveSize    = 0 ; T.WaterWaveSpeed   = 0
        T.WaterReflectance = 0 ; T.WaterTransparency= 1
        L.GlobalShadows    = false ; L.FogEnd = 9e9 ; L.FogStart = 0
        L.Brightness       = 1.5 ; L.ClockTime = 12 ; L.GeographicLatitude = 0
        L.Ambient = Color3.new(1,1,1) ; L.OutdoorAmbient = Color3.new(1,1,1)
        settings().Rendering.QualityLevel = "Level01"

        local function rm(obj)
            if not obj or not obj.Parent then return end
            local cls = obj.ClassName
            if cls=="ParticleEmitter" or cls=="Trail" or cls=="Fire"
            or cls=="Smoke"          or cls=="Sparkles" then
                pcall(function() obj.Enabled=false obj:Destroy() end)
            elseif cls=="SpotLight" or cls=="PointLight" or cls=="SurfaceLight" then
                pcall(function() obj.Enabled=false obj:Destroy() end)
            elseif cls=="Beam" then
                pcall(function() obj.Enabled=false obj:Destroy() end)
            elseif cls=="Sound" then
                pcall(function() obj:Stop() obj:Destroy() end)
            elseif cls=="Decal" or cls=="Texture" then
                pcall(function() obj:Destroy() end)
            end
        end

        local atm = L:FindFirstChild("Atmosphere")
        if atm then pcall(function() atm:Destroy() end) end
        for _, e in ipairs(L:GetChildren()) do
            if e:IsA("PostEffect") then
                pcall(function() e.Enabled=false e:Destroy() end)
            end
        end
        for _, v in ipairs(WS:GetDescendants()) do rm(v) end
    end)
    task.delay(0.5, function() collectgarbage() collectgarbage() end)
end

