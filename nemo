end

--==============================================================================
-- SECTION 17 : AUTO FARM STATE MACHINE
--   States: IDLE → GET_QUEST → TRAVEL_TO_NPC → ACCEPT_QUEST
--           → FIND_MOB → COMBAT → (back to GET_QUEST)
--==============================================================================
local AutoFarm = { state = "IDLE", questData = nil, cooldown = 0 }

local function autoFarmTick()
    if AutoFarm.state == "IDLE" then return end
    local now = tick()
    if now < AutoFarm.cooldown then return end

    local hrp = getHRP()
    if not hrp then return end

    if AutoFarm.state == "GET_QUEST" then
        AutoFarm.questData = QuestModule.GetCurrentData()
        if not AutoFarm.questData then return end

        if QuestModule.HasActiveQuest() then
            local title = QuestModule.GetActiveTitle()
            if not string.find(title, AutoFarm.questData.MobName, 1, true) then
                QuestModule.Abandon()
                AutoFarm.cooldown = now + 0.6
            else
                AutoFarm.state = "FIND_MOB"
            end
        else
            AutoFarm.state = "TRAVEL_TO_NPC"
        end

    elseif AutoFarm.state == "TRAVEL_TO_NPC" then
        local npcPos = AutoFarm.questData.NPCPos
        TpModule.Go(npcPos, CFG.BringSpeed)
        if (hrp.Position - npcPos.Position).Magnitude < 10 then
            AutoFarm.state    = "ACCEPT_QUEST"
        end

    elseif AutoFarm.state == "ACCEPT_QUEST" then
        QuestModule.Accept(AutoFarm.questData)
        AutoFarm.cooldown = now + 0.7
        AutoFarm.state    = "FIND_MOB"

    elseif AutoFarm.state == "FIND_MOB" then
        if not QuestModule.HasActiveQuest() then
            AutoFarm.state = "GET_QUEST"
            return
        end

        local mobs = MobModule.GetAlive(AutoFarm.questData.MobName)
        if #mobs == 0 then return end

        local target    = mobs[1]
        local targetHRP = target:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        -- Bay cao hơn mob, dùng TpModule thay vì TweenCFrame trực tiếp
        local flyTarget = targetHRP.CFrame + CFG.FlyOffset
        TpModule.Go(flyTarget, CFG.BringSpeed)

        -- Gom quái về centroid
        MobModule.BringAll(AutoFarm.questData.MobName)
    end
end

function AutoFarm.Start()
    TpModule.SetActive(true)
    AutoFarm.state = "GET_QUEST"
    -- Cập nhật anchor về vị trí hiện tại để tránh nhảy xa
    local hrp = getHRP()
    if hrp then _anchor.CFrame = hrp.CFrame end
end

function AutoFarm.Stop()
    AutoFarm.state = "IDLE"
    TpModule.SetActive(false)
    if TpModule._tween then TpModule._tween:Cancel() end
    -- Cleanup BodyVelocity cũ (compat với v2)
    local hrp = getHRP()
    if hrp then
        local bv = hrp:FindFirstChild("NemoHoverBV")
        if bv then bv:Destroy() end
    end
end

