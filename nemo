                break
            end
        end
        task.wait(0.05)
        pressKey(key)
    end)
end

-- Debounce chống Kick: giới hạn tốc độ fire remote, không để server flag spam
local _attackDebounce   = false
local _attackLastFire   = 0
local _attackMinGap     = 0.08  -- (giây) khoảng cách tối thiểu giữa 2 lần fire

function CombatModule.FastAttack()
    if _attackDebounce then return end
    local now = tick()
    if now - _attackLastFire < _attackMinGap then return end
    _attackDebounce  = true
    _attackLastFire  = now
    pcall(function()
        local char = getChar()
        if not char or not char:FindFirstChildOfClass("Tool") then
            _attackDebounce = false return
        end
        local mobs = MobModule.GetAlive(nil)
        if #mobs == 0 then _attackDebounce = false return end
        local parts = {}
        for _, mob in ipairs(mobs) do
            local h = mob:FindFirstChild("Head")
            if h then table.insert(parts, {mob, h}) end
        end
        if #parts == 0 then _attackDebounce = false return end
        Remote.RegisterAttack:FireServer(CFG.AttackRate)
        Remote.RegisterHit:FireServer(parts[1][2], parts)
    end)
    _attackDebounce = false
end

--==============================================================================
-- SECTION 10: NAMECALL HOOK  (BoneHub MousePos injection)
--==============================================================================
local NamecallModule = { enabled = false, _hooked = false }
local _MousePos = Vector3.zero

function NamecallModule.Enable()
    if NamecallModule._hooked then
        NamecallModule.enabled = true
        return
    end
    pcall(function()
        local gg  = getrawmetatable(game)
        local old = gg.__namecall
        setreadonly(gg, false)
        gg.__namecall = newcclosure(function(...)
            local method = getnamecallmethod()
            local args   = {...}
            if NamecallModule.enabled and tostring(method) == "FireServer" then
                if tostring(args[1]) == "RemoteEvent" then
                    args[2] = _MousePos
                    return old(unpack(args))
                end
            end
            return old(...)
        end)
        setreadonly(gg, true)
        NamecallModule._hooked  = true
        NamecallModule.enabled  = true
    end)
end

function NamecallModule.Disable()
    NamecallModule.enabled = false
end

task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if NamecallModule.enabled then
                local mobs = MobModule.GetAlive(nil)
                if #mobs > 0 then
                    local h = mobs[1]:FindFirstChild("HumanoidRootPart")
                    if h then _MousePos = h.Position end
                end
            end
        end)
    end
end)

