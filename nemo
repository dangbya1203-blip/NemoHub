-- SECTION 6: REMOTES — lazy init, luôn trả về callable object
--==============================================================================
local _noopObj  = { FireServer = noop, InvokeServer = noop }
local function getRemote(...)
    return safeFind(RS, ...) or _noopObj
end

-- Cache lần đầu dùng, không crash nếu RS chưa ready
local Remote = setmetatable({}, {
    __index = function(t, k)
        local map = {
            CommF         = function() return safeFind(RS,"Remotes","CommF_") or _noopObj end,
            RegisterAttack= function() return RS:FindFirstChild("RegisterAttack") or _noopObj end,
            RegisterHit   = function() return RS:FindFirstChild("RegisterHit") or _noopObj end,
            ServerBrowser = function() return RS:FindFirstChild("__ServerBrowser") or _noopObj end,
        }
        local v = map[k] and map[k]() or _noopObj
        rawset(t, k, v)
        return v
    end
})

--==============================================================================
-- SECTION 7: ANCHOR-BLOCK TELEPORT  (BoneHub _tp technique)
--==============================================================================
local TpModule   = { _active = false, _tween = nil }
local _anchor    = nil

-- Tạo anchor block an toàn
pcall(function()
    _anchor            = Instance.new("Part")
    _anchor.Name       = "NemoAnchor"
    _anchor.Size       = Vector3.new(1,1,1)
    _anchor.Anchored   = true
    _anchor.CanCollide = false
    _anchor.CanTouch   = false
    _anchor.Transparency = 1
    _anchor.Parent     = WS
end)

function TpModule.Go(targetCF, speed)
    if not _anchor or not targetCF then return end
    speed = speed or CFG.BringSpeed
    pcall(function()
        local dist = (targetCF.Position - _anchor.Position).Magnitude
        if dist < 1 then return end
        if TpModule._tween then TpModule._tween:Cancel() end
        local tw = TW:Create(_anchor, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), { CFrame = targetCF })
        TpModule._tween = tw
        tw:Play()
        task.spawn(function()
            while tw.PlaybackState == Enum.PlaybackState.Playing do
                if not TpModule._active then tw:Cancel() return end
                task.wait(0.05)
            end
        end)
    end)
end

function TpModule.SetActive(state)
    TpModule._active = state
    pcall(function()
        local char = getChar()
        if char then
            for _, p in ipairs(char:GetChildren()) do
                if p:IsA("BasePart") then p.CanCollide = not state end
            end
        end
    end)
end

-- Character follow anchor
task.spawn(function()
    while task.wait() do
        pcall(function()
            if TpModule._active and _anchor then
                local hrp = getHRP()
                if hrp then
                    if (hrp.Position - _anchor.Position).Magnitude > 200 then
                        _anchor.CFrame = hrp.CFrame
                    else
                        hrp.CFrame = _anchor.CFrame
                    end
                end
            end
        end)
    end
end)

