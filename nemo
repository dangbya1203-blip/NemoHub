local function getCharacter()
    local char = LocalPlayer.Character
    if not char then
        local conn; local done = false
        conn = LocalPlayer.CharacterAdded:Connect(function(c) char = c; done = true end)
        local t = tick()
        while not done and (tick() - t < 10) do task.wait(0.1) end
        conn:Disconnect()
    end
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        local ok = pcall(function() char:WaitForChild("HumanoidRootPart", 5) end)
        if not ok then return nil end
    end
    return char
end
local function toggleNoclip(on)
    pcall(function()
        local char = getCharacter()
        if not char then return end
        for _, v in ipairs(char:GetChildren()) do if v:IsA("Part") then v.CanCollide = not on end end
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Seated, not on) end
    end)
end

local TWEEN_SPEED = 300
local _activeTween = nil
local function _ensureBV(hrp)
    if not hrp:FindFirstChild("BodyClip") then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "BodyClip"; bv.Parent = hrp
        bv.MaxForce = Vector3.new(100000,100000,100000); bv.Velocity = Vector3.zero
    end
end
local function _removeBV(hrp)
    local bp = hrp and hrp:FindFirstChild("BodyClip")
    if bp then bp:Destroy() end
end

local function TweenPlayer(goalCF, ignoreStop)
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist = (hrp.Position - goalCF.Position).Magnitude
    if dist < 1 then return end
    if _activeTween and _activeTween.PlaybackState == Enum.PlaybackState.Playing then
        _activeTween:Cancel()
    end
    toggleNoclip(true)
    _ensureBV(hrp)
    _activeTween = TweenService:Create(hrp, TweenInfo.new(dist/TWEEN_SPEED, Enum.EasingStyle.Linear), {CFrame=goalCF})
    _activeTween:Play()
    local done = false
    _activeTween.Completed:Connect(function() done = true end)
    while not done and (ignoreStop or getgenv().NemoRunning) do
        task.wait(0.1)
        local c2 = LocalPlayer.Character
        local h2 = c2 and c2:FindFirstChild("HumanoidRootPart")
        if not h2 or h2 ~= hrp then
            pcall(function() _activeTween:Cancel() end)
            done = true
        end
    end
    toggleNoclip(false)
    _removeBV(hrp)
end

local function SafeTweenTP(goalCF) TweenPlayer(goalCF) end

local function Teleport(Goal, Speed)
    local char = getCharacter()
    if not char then return end
    local RootPart = char:FindFirstChild("HumanoidRootPart")
    if not RootPart then return end
    if InstantTP then RootPart.CFrame = Goal; return end
    Speed = Speed or MaxSpeed
    toggleNoclip(true)
    pcall(function()
        local Mag = (RootPart.Position - Goal.Position).Magnitude
        while Mag > 1 and getgenv().NemoRunning do
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
            local Dir = (Goal.Position - RootPart.Position).unit
            local Next = RootPart.Position + Dir * math.min(Speed * task.wait(), Mag)
            if (Next - Goal.Position).Magnitude < 1 then RootPart.CFrame = Goal; break end
            RootPart.CFrame = CFrame.new(Next)
            Mag = (RootPart.Position - Goal.Position).Magnitude
        end
    end)
    toggleNoclip(false)
end

