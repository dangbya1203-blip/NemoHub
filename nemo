-- SECTION 8: MOB MODULE  (Centroid Bring + Animator:Destroy)
--==============================================================================
local MobModule = {}

local function getMobCentroid(name)
    local sum, n = Vector3.zero, 0
    pcall(function()
        for _, v in ipairs(WS.Enemies:GetChildren()) do
            local hrp = v:FindFirstChild("HumanoidRootPart")
            if v.Name == name and hrp then
                sum = sum + hrp.Position
                n   = n + 1
            end
        end
    end)
    return n > 0 and (sum / n) or nil
end

function MobModule.GetAlive(filter)
    local result = {}
    pcall(function()
        local container = WS:FindFirstChild("Enemies")
        if not container then return end
        for _, v in ipairs(container:GetChildren()) do
            local hum = v:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                if (not filter) or v.Name == filter then
                    table.insert(result, v)
                end
            end
        end
    end)
    return result
end

function MobModule.BringAll(filter)
    pcall(function()
        local hrp = getHRP()
        if not hrp then return end
        local enemies = WS:FindFirstChild("Enemies")
        if not enemies then return end

        -- Tính centroid mỗi loại một lần
        local centroids = {}
        for _, v in ipairs(enemies:GetChildren()) do
            if (not filter) or v.Name == filter then
                if not centroids[v.Name] then
                    centroids[v.Name] = getMobCentroid(v.Name)
                end
            end
        end

        -- Tween từng mob về centroid
        for _, v in ipairs(enemies:GetChildren()) do
            pcall(function()
                local hum    = v:FindFirstChild("Humanoid")
                local mobHRP = v:FindFirstChild("HumanoidRootPart")
                if not (hum and mobHRP and hum.Health > 0) then return end
                if filter and v.Name ~= filter then return end
                if (mobHRP.Position - hrp.Position).Magnitude > CFG.BringRadius then return end

                local c = centroids[v.Name]
                if not c then return end
                local cf  = CFrame.new(c.X, c.Y, c.Z)
                local md  = (mobHRP.Position - c).Magnitude
                if md > 3 and md <= 280 then
                    TW:Create(mobHRP, TweenInfo.new(md/CFG.BringSpeed,Enum.EasingStyle.Linear), {CFrame=cf}):Play()
                    mobHRP.CanCollide = false
                    hum.WalkSpeed     = 0
                    hum.JumpPower     = 0
                    -- BoneHub: xóa Animator → mob đứng im hoàn toàn
                    local anim = hum:FindFirstChild("Animator")
                    if anim then pcall(function() anim:Destroy() end) end
                    pcall(function() sethiddenproperty(Plr,"SimulationRadius",math.huge) end)
                end
            end)
        end
    end)
end

