local SEA2_PLACE = 4442274612
local SEA3_PLACE = 7449423635

-- Fallback: nhảy + dịch chuyển vật lý vào rương khi firetouchinterest thất bại
local function jumpIntoChest(RootPart, Chest, maxAttempts)
    maxAttempts = maxAttempts or 4
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    for attempt = 1, maxAttempts do
        if not Chest or not Chest.Parent then return end
        local angle        = (attempt - 1) * (math.pi * 2 / maxAttempts) + math.random() * 0.3
        local approachDist = hrand(1.5, 2.5)
        RootPart.CFrame    = Chest.CFrame * CFrame.new(math.cos(angle) * approachDist, 1.5, math.sin(angle) * approachDist)
        RunService.Heartbeat:Wait()

        hum.Jump = true
        pcall(function()
            RootPart.AssemblyLinearVelocity = (Chest.Position - RootPart.Position).Unit * 28
        end)
        task.wait(TOUCH_FIRE_WAIT)
        RootPart.CFrame = Chest.CFrame * CFrame.new(0, 0.3, 0)

        pcall(function()
            if firetouchinterest then
                firetouchinterest(RootPart, Chest, 0)
                task.wait(TOUCH_FIRE_WAIT)
                firetouchinterest(RootPart, Chest, 1)
            end
        end)
        -- Không chờ rương biến mất — sang attempt tiếp hoặc thoát
        if not Chest or not Chest.Parent then return end
    end
end

-- Touch chest: fire xong sang rương tiếp theo ngay, không chờ rương biến mất
local function TouchChest(RootPart, Chest)
    RootPart.CFrame = jitterCF(Chest.CFrame * CFrame.new(0, 0.5, 0))

    local fired = false
    pcall(function()
        if firetouchinterest then
            firetouchinterest(RootPart, Chest, 0)
            task.wait(TOUCH_FIRE_WAIT)   -- 0.02s thay vì 0.07-0.11s
            firetouchinterest(RootPart, Chest, 1)
            fired = true
        end
    end)

    -- Nếu không có firetouchinterest thì dùng jump fallback
    if not fired then
        jumpIntoChest(RootPart, Chest)
    end
end

local function GrabFruit(RootPart, fruit)
    local handle = fruit:FindFirstChild("Handle")
    if not handle then return end
    -- Jitter nhẹ vị trí lụm trái, không đứng chính xác tâm
    local targetCF = jitterCF(handle.CFrame, 0.3)
    Teleport(targetCF)
    RootPart.CFrame = targetCF
    pcall(function()
        if firetouchinterest then
            firetouchinterest(RootPart, handle, 0)
            task.wait(TOUCH_FIRE_WAIT)
            firetouchinterest(RootPart, handle, 1)
        end
    end)
    task.wait(hrand(0.10, 0.15))   -- đủ để server xác nhận nhặt trái
    StoreFruit()
end

-- Kiểm tra ngắt giữa chest loop
local function ShouldBreakChest()
    if CollectFruit and #GetDroppedFruits() > 0 then return true end
    if AutoDoughKing and PlaceId == SEA3_PLACE then
        if GetBP("God's Chalice") or GetBP("Sweet Chalice") then return true end
    end
    if AutoDarkbeard and PlaceId == SEA2_PLACE then
        if HasFistOfDarkness() or GetDarkbeard() then return true end
    end
    return false
end

local function main()
    AutoSelectTeam()

    -- Không chờ map load — farm ngay, DescendantAdded + FirstRun scan tự fill rương.


    while true do
        local char = LocalPlayer.Character
        local RootPart = char and char:FindFirstChild("HumanoidRootPart")
        if not RootPart then task.wait(1); continue end

        -- [ƯU TIÊN 1] Lụm Trái
        if CollectFruit then
            local fruits = GetDroppedFruits()
            if #fruits > 0 then
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Phát hiện Trái! Đang lụm..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                GrabFruit(RootPart, fruits[1])
                task.wait(0.3)
                continue
            end
        end

        -- [ƯU TIÊN 2] Dough King (Sea 3)
        if AutoDoughKing and PlaceId == SEA3_PLACE then
            RunDoughKingChain()
            task.wait(0.05)
            continue
        end

        -- [ƯU TIÊN 3] Darkbeard (Sea 2)
        if AutoDarkbeard and PlaceId == SEA2_PLACE then
            local darkbeard = GetDarkbeard()
            if darkbeard then
                _G.IsAttackingBoss = true
                StatusLabel.Text = "Status: Đánh Darkbeard!!!"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                PositionOnBoss(darkbeard)
                task.wait(0.05)
                continue
            elseif HasFistOfDarkness() then
                _G.IsAttackingBoss = false
                StatusLabel.Text = "Status: Chờ Darkbeard spawn..."
                StatusLabel.TextColor3 = Color3.fromRGB(150, 50, 255)
                EquipFist()
                RootPart.CFrame = CFrame.new(3677.08203125, 62.751937866211, -3144.8332519531)
                local hum = char:FindFirstChild("Humanoid")
                if hum then hum.Jump = true end
                task.wait(1)
                continue
            end
        end

        -- [ƯU TIÊN 4] Auto Chest
        _G.IsAttackingBoss = false
        StatusLabel.Text = "Status: Auto Chest (Instant)"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)

        local Chests = getChestsSorted()
        if #Chests == 0 then
            -- Không có rương: giả lập hoạt động 3s (anti-kick) rồi hop ngay.
            -- Không tele trong lúc chờ — tele khi không có rương sẽ bị kick.
            StatusLabel.Text = "Status: Không có rương, chờ 3s rồi hop..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            local antiKickEnd = tick() + 3
            while tick() < antiKickEnd do
                pcall(function()
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton2(Vector2.new(
                        math.random(200, 600), math.random(200, 500)
                    ))
                end)
                task.wait(0.8)
            end
            HopServer()
            break
        end

        for _, Chest in ipairs(Chests) do
            if ShouldBreakChest() then break end
            -- Refresh RootPart phòng respawn giữa chừng
            char = LocalPlayer.Character
            RootPart = char and char:FindFirstChild("HumanoidRootPart")
            if not RootPart then break end
            if Chest and Chest.Parent and Chest:FindFirstChild("TouchInterest") then
                TouchChest(RootPart, Chest)
                IgnoredChests[Chest] = tick()
            end
        end

        task.wait()  -- 1 frame (~0.016s) thay vì 0.05s
    end
end

