    local function hasRealTeam()
        if LocalPlayer:FindFirstChild("Main") then return true end
        local t = LocalPlayer.Team
        return t ~= nil and t.Name ~= "Neutral" and t.Name ~= ""
    end
    if hasRealTeam() then return end

    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    local teamName  = JoinTeam  -- "Pirates" hoặc "Marines"

    local function trySelectTeam()
        -- Cách 1: CommF_ InvokeServer trực tiếp (không cần UI)
        pcall(function()
            RS.Remotes.CommF_:InvokeServer("SelectTeam", teamName)
        end)

        -- Cách 2: getconnections vào button Activated
        pcall(function()
            local mainMinimal = PlayerGui:FindFirstChild("Main (minimal)")
            if not mainMinimal then return end
            local chooseTeam = mainMinimal:FindFirstChild("ChooseTeam", true)
            if not chooseTeam then return end

            -- Tìm button theo tên phe, duyệt toàn bộ descendants để không lệ thuộc path cứng
